---
const services = [
  { label: 'Modular Kitchen', href: '/services/modular-kitchen' },
  { label: 'Wardrobes & Bedroom', href: '/services/wardrobes-bedroom' },
  { label: 'Furniture Repair', href: '/services/furniture-repair' },
  { label: 'All Services', href: '/services' },
];
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="/" class="footer-logo">
        <span class="logo-vs">VS</span>
        <span class="logo-name">Furnitures</span>
      </a>
      <p class="footer-tagline">Furniture contractor & custom carpentry, serving all of Indore since 1990.</p>
      <div class="footer-contact">
        <a href="tel:+919827348796" class="footer-contact-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
          9827348796
        </a>
        <a href="https://wa.me/919977250002?text=Hi%20VS%20Furnitures%2C%20I%20found%20your%20website%20and%20I%27d%20like%20a%20free%20estimate%20for%20______" target="_blank" rel="noopener" class="footer-contact-link wa">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp: 9977250002
        </a>
      </div>
      <p class="footer-hours">Mon–Sun &nbsp;·&nbsp; 9:00 AM – 8:00 PM</p>
    </div>

    <div class="footer-col">
      <h4 class="footer-heading">Services</h4>
      <ul>
        {services.map(s => <li><a href={s.href}>{s.label}</a></li>)}
      </ul>
    </div>

    <div class="footer-col">
      <h4 class="footer-heading">Quick Links</h4>
      <ul>
        <li><a href="/our-work">Our Work</a></li>
        <li><a href="/about">About Us</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h4 class="footer-heading">Areas We Serve</h4>
      <div class="footer-areas">
        <a href="/carpenter-vijay-nagar-indore" class="footer-area-link">Vijay Nagar</a>
        <a href="/carpenter-palasia-indore" class="footer-area-link">Palasia</a>
        <a href="/carpenter-nipaniya-indore" class="footer-area-link">Nipaniya</a>
        <a href="/carpenter-annapurna-indore" class="footer-area-link">Annapurna</a>
        <a href="/carpenter-nanda-nagar-indore" class="footer-area-link">Nanda Nagar</a>
        <a href="/carpenter-scheme-54-indore" class="footer-area-link">Scheme 54</a>
        <a href="/carpenter-ab-road-indore" class="footer-area-link">AB Road</a>
        <a href="/carpenter-rau-indore" class="footer-area-link">Rau</a>
        <span class="footer-area-plain">Mahalaxmi Nagar · Tulsi Nagar · Rajendra Nagar · Niranjanpur · Omex City · Dewas Naka · MR-10</span>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container">
      <p>© {year} VS Furnitures · Furniture Contractor & Carpenter, Indore</p>
    </div>
  </div>
</footer>

<style>
.site-footer {
  background: var(--navy-deep);
  color: rgba(255,255,255,0.75);
  margin-top: 0;
}
.footer-inner {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1.5fr;
  gap: 3rem;
  padding: 64px 1.25rem 48px;
}
.footer-logo {
  display: flex;
  align-items: baseline;
  gap: 0.35rem;
  margin-bottom: 0.75rem;
  text-decoration: none;
}
.footer-logo .logo-vs { font-family: var(--font-head); font-size: 1.4rem; font-weight: 700; color: var(--gold); }
.footer-logo .logo-name { font-family: var(--font-body); font-size: 0.95rem; font-weight: 600; color: var(--white); }
.footer-tagline { font-size: 0.88rem; line-height: 1.6; margin-bottom: 1rem; color: rgba(255,255,255,0.65); }
.footer-contact { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 0.75rem; }
.footer-contact-link {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--white);
  text-decoration: none;
  transition: color 0.15s;
}
.footer-contact-link:hover { color: var(--gold); }
.footer-contact-link.wa svg { color: #25D366; }
.footer-hours { font-size: 0.82rem; color: rgba(255,255,255,0.5); }
.footer-heading {
  font-family: var(--font-body);
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 1rem;
}
.footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }
.footer-col a { font-size: 0.88rem; color: rgba(255,255,255,0.7); transition: color 0.15s; }
.footer-col a:hover { color: var(--white); }
.footer-areas { display: flex; flex-wrap: wrap; gap: 0.4rem 0.5rem; align-items: center; }
.footer-area-link { font-size: 0.78rem; font-weight: 600; color: rgba(255,255,255,0.85); background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); border-radius: 40px; padding: 0.2rem 0.7rem; text-decoration: none; transition: background 0.15s, color 0.15s; white-space: nowrap; }
.footer-area-link:hover { background: var(--gold); color: var(--navy); border-color: var(--gold); }
.footer-area-plain { font-size: 0.78rem; color: rgba(255,255,255,0.45); line-height: 1.7; }
.footer-bottom {
  border-top: 1px solid rgba(255,255,255,0.08);
  padding: 1.25rem 0;
  text-align: center;
  font-size: 0.8rem;
  color: rgba(255,255,255,0.4);
}
@media (max-width: 900px) {
  .footer-inner { grid-template-columns: 1fr 1fr; gap: 2rem; }
  .footer-brand { grid-column: 1 / -1; }
}
@media (max-width: 600px) {
  .footer-inner { grid-template-columns: 1fr; }
}
</style>
