---
const nav = [
  { label: 'Home', href: '/' },
  { label: 'Services', href: '/services' },
  { label: 'Our Work', href: '/our-work' },
  { label: 'Why Us', href: '/why-us' },
  { label: 'How We Work', href: '/how-we-work' },
  { label: 'About', href: '/about' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];
const path = Astro.url.pathname;
---
<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="logo" aria-label="VS Furnitures home">
      <span class="logo-vs">VS</span>
      <span class="logo-name">Furnitures</span>
    </a>

    <nav class="main-nav" aria-label="Main navigation">
      {nav.map(link => (
        <a href={link.href} class:list={['nav-link', { active: path === link.href || (link.href !== '/' && path.startsWith(link.href)) }]}>
          {link.label}
        </a>
      ))}
    </nav>

    <div class="header-cta">
      <a href="tel:+919827348796" class="btn btn-primary btn-sm">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
        Call
      </a>
      <a href="https://wa.me/919977250002?text=Hi%20VS%20Furnitures%2C%20I%20found%20your%20website%20and%20I%27d%20like%20a%20free%20estimate%20for%20______" target="_blank" rel="noopener" class="btn btn-wa btn-sm">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        WhatsApp
      </a>
    </div>

    <button class="menu-toggle" id="menuToggle" aria-label="Open menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile drawer -->
  <div class="mobile-nav" id="mobileNav" aria-hidden="true">
    {nav.map(link => (
      <a href={link.href} class="mobile-nav-link">{link.label}</a>
    ))}
    <div class="mobile-nav-cta">
      <a href="tel:+919827348796" class="btn btn-primary">Call 9827348796</a>
      <a href="https://wa.me/919977250002?text=Hi%20VS%20Furnitures%2C%20I%20found%20your%20website%20and%20I%27d%20like%20a%20free%20estimate%20for%20______" target="_blank" rel="noopener" class="btn btn-wa">WhatsApp Us</a>
    </div>
  </div>
</header>

<style>
.site-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: var(--navy);
  box-shadow: 0 2px 16px rgba(0,0,0,0.18);
}
.header-inner {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  height: var(--header-h);
}
.logo {
  display: flex;
  align-items: baseline;
  gap: 0.35rem;
  text-decoration: none;
  flex-shrink: 0;
}
.logo-vs {
  font-family: var(--font-head);
  font-size: 1.6rem;
  font-weight: 700;
  color: var(--gold);
  letter-spacing: 0.03em;
}
.logo-name {
  font-family: var(--font-body);
  font-size: 1.05rem;
  font-weight: 600;
  color: var(--white);
  letter-spacing: 0.04em;
}
.main-nav {
  display: flex;
  align-items: center;
  gap: 0.25rem;
  flex: 1;
  justify-content: center;
}
.nav-link {
  font-size: 0.88rem;
  font-weight: 600;
  color: rgba(255,255,255,0.78);
  padding: 0.4rem 0.7rem;
  border-radius: 4px;
  transition: color 0.15s, background 0.15s;
  letter-spacing: 0.02em;
}
.nav-link:hover, .nav-link.active {
  color: var(--white);
  background: rgba(255,255,255,0.1);
}
.nav-link.active { color: var(--gold); background: none; }
.header-cta { display: flex; gap: 0.5rem; flex-shrink: 0; }
.btn-sm { padding: 0.5rem 1rem; font-size: 0.82rem; }
.menu-toggle {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
  margin-left: auto;
}
.menu-toggle span {
  display: block;
  width: 24px;
  height: 2px;
  background: var(--white);
  border-radius: 2px;
  transition: all 0.2s;
}
.mobile-nav {
  display: none;
  flex-direction: column;
  padding: 1rem 1.25rem 1.5rem;
  background: var(--navy-deep);
  gap: 0.25rem;
}
.mobile-nav.open { display: flex; }
.mobile-nav-link {
  color: rgba(255,255,255,0.85);
  font-weight: 600;
  font-size: 1rem;
  padding: 0.65rem 0;
  border-bottom: 1px solid rgba(255,255,255,0.08);
}
.mobile-nav-link:last-of-type { border: none; }
.mobile-nav-cta { display: flex; gap: 0.75rem; margin-top: 1rem; flex-wrap: wrap; }
@media (max-width: 900px) {
  .main-nav { display: none; }
  .header-cta { display: none; }
  .menu-toggle { display: flex; }
}
</style>

<script>
const toggle = document.getElementById('menuToggle');
const nav = document.getElementById('mobileNav');
toggle?.addEventListener('click', () => {
  const open = nav?.classList.toggle('open');
  toggle.setAttribute('aria-expanded', String(open));
  nav?.setAttribute('aria-hidden', String(!open));
});
</script>
