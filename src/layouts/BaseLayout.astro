---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import MobileBar from '../components/MobileBar.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
  noindex?: boolean;
  additionalSchemas?: object[];
}

const { title, description, ogImage = '/images/og-default.jpg', canonical, noindex = false, additionalSchemas = [] } = Astro.props;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).href;

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": "https://vsfurnitures.in/#business",
  "name": "VS Furnitures",
  "alternateName": "VS Furniture Contractor Indore",
  "description": "Trusted carpenter and furniture contractor in Indore with 30+ years experience. Modular kitchens, wardrobes, repairs and custom carpentry. Free site visit within 7 km.",
  "url": "https://vsfurnitures.in",
  "telephone": "+919827348796",
  "image": "https://vsfurnitures.in/images/og-default.jpg",
  "logo": "https://vsfurnitures.in/images/og-default.jpg",
  "priceRange": "₹₹",
  "currenciesAccepted": "INR",
  "paymentAccepted": "Cash, Bank Transfer",
  "foundingDate": "1990",
  "areaServed": [
    "Vijay Nagar, Indore", "Palasia, Indore", "Mahalaxmi Nagar, Indore",
    "Tulsi Nagar, Indore", "Rajendra Nagar, Indore", "Nipaniya, Indore",
    "Niranjanpur, Indore", "Annapurna, Indore", "Nanda Nagar, Indore",
    "Scheme 54, Indore", "AB Road, Indore", "Rau, Indore",
    "Bicholi, Indore", "MR-10, Indore", "Dewas Naka, Indore"
  ],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Indore",
    "addressRegion": "Madhya Pradesh",
    "postalCode": "452011",
    "addressCountry": "IN"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "22.7196",
    "longitude": "75.8577"
  },
  "openingHoursSpecification": [{
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
    "opens": "09:00",
    "closes": "20:00"
  }],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5",
    "reviewCount": "28",
    "bestRating": "5",
    "worstRating": "1"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Carpentry and Furniture Services",
    "itemListElement": [
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Modular Kitchen","url":"https://vsfurnitures.in/services/modular-kitchen"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Wardrobes and Bedroom Furniture","url":"https://vsfurnitures.in/services/wardrobes-bedroom"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Furniture Repair and Polishing","url":"https://vsfurnitures.in/services/furniture-repair"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Office Furniture","url":"https://vsfurnitures.in/services/office-furniture"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Living Room Furniture","url":"https://vsfurnitures.in/services/living-room"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"False Ceiling and Wood Paneling","url":"https://vsfurnitures.in/services/false-ceiling"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Custom Carpentry","url":"https://vsfurnitures.in/services/custom-carpentry"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Door and Window Frames","url":"https://vsfurnitures.in/services/door-window-frames"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Furniture Assembly and Dismantling","url":"https://vsfurnitures.in/services/furniture-assembly"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Old Furniture Restoration","url":"https://vsfurnitures.in/services/furniture-restoration"}}
    ]
  },
  "sameAs": ["https://wa.me/919977250002"]
};
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#102542" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />

    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="VS Furnitures" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} is:inline />
    {additionalSchemas.map(schema => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} is:inline />
    ))}
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <WhatsAppButton />
    <MobileBar />

    <script>
      document.body.classList.add('js-reveal');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
            observer.unobserve(e.target);
          }
        });
      }, { threshold: 0.08 });
      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    </script>
  </body>
</html>
