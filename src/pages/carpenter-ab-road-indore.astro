---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABand from '../components/CTABand.astro';

const area = 'AB Road';
const areaSlug = 'ab-road';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type":"ListItem","position":1,"name":"Home","item":"https://vsfurnitures.in"},
    {"@type":"ListItem","position":2,"name":"Carpenter in AB Road","item":`https://vsfurnitures.in/carpenter-${areaSlug}-indore/`}
  ]
};

const localSchema = {
  "@context": "https://schema.org",
  "@type": "Carpenter",
  "@id": `https://vsfurnitures.in/carpenter-${areaSlug}-indore/#carpenter`,
  "name": "Carpenter. Vs Furniture & Home Solution",
  "url": "https://vsfurnitures.in",
  "telephone": "+919827348796",
  "areaServed": `${area}, Indore`
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Do you cover both residential and office properties on AB Road?",
      "acceptedAnswer": {"@type": "Answer", "text": "Yes — AB Road has a mix of residential apartments, independent bungalows, and commercial properties. We handle both residential furniture (kitchens, wardrobes, living room) and office furniture (workstations, reception counters, conference tables) across the full length of AB Road."}
    },
    {
      "@type": "Question",
      "name": "Can you build custom office furniture for businesses on AB Road?",
      "acceptedAnswer": {"@type": "Answer", "text": "Absolutely. We regularly build office workstations, reception counters, conference tables, and storage cabinets for small offices and businesses along AB Road. Work is built to your office's exact dimensions, and we can usually complete a small office fit-out in 10 to 14 days."}
    },
    {
      "@type": "Question",
      "name": "Which residential colonies on and around AB Road do you serve?",
      "acceptedAnswer": {"@type": "Answer", "text": "We serve all residential areas on and adjacent to AB Road — Nipaniya, Mahalaxmi Nagar, Scheme 54, Vijay Nagar (AB Road side), Sindhi Colony, County Walk, and all the apartment buildings and bungalows along the AB Road corridor."}
    },
    {
      "@type": "Question",
      "name": "How quickly can you visit for a site visit on AB Road?",
      "acceptedAnswer": {"@type": "Answer", "text": "We can typically schedule a free site visit on AB Road within 24 hours. For urgent repair calls, same-day or next-morning visits are usually possible. Call 9827348796 to confirm availability."}
    },
    {
      "@type": "Question",
      "name": "Do you handle furniture work in high-rise apartments on AB Road?",
      "acceptedAnswer": {"@type": "Answer", "text": "Yes — we work in high-rise buildings across AB Road including gated societies with security check-in. We are comfortable with lift access, working within society timings, and managing materials in multi-floor buildings."}
    }
  ]
};

const services = [
  { name: 'Modular Kitchen', href: '/services/modular-kitchen' },
  { name: 'Wardrobes & Bedroom', href: '/services/wardrobes-bedroom' },
  { name: 'Living Room & TV Units', href: '/services/living-room' },
  { name: 'Office Furniture', href: '/services/office-furniture' },
  { name: 'Furniture Repair & Polishing', href: '/services/furniture-repair' },
  { name: 'Custom Carpentry', href: '/services/custom-carpentry' },
  { name: 'False Ceiling & Paneling', href: '/services/false-ceiling' },
  { name: 'Furniture Assembly', href: '/services/furniture-assembly' },
  { name: 'Old Furniture Restoration', href: '/services/furniture-restoration' },
  { name: 'Door & Window Frames', href: '/services/door-window-frames' },
];

const reviews = [
  {
    name: 'Rohit Rathore', stars: 5, service: 'Living Room Furniture', area: 'AB Road',
    text: 'Got a custom TV unit and wall shelving made for my living room. Very different from the standard stuff you see. Exactly the design I wanted.'
  },
  {
    name: 'Hemant Jain', stars: 5, service: 'Living Room Furniture', area: 'AB Road',
    text: 'Entertainment unit with back-lit shelves and a side cabinet. Looks stunning in the evening. The backlit effect was their idea and it really elevates the room.'
  },
];
---
<BaseLayout
  title="Carpenter in AB Road Indore | VS Furnitures"
  description="Carpenter in AB Road, Indore — VS Furnitures. Modular kitchens, wardrobes, furniture repair and custom carpentry. 30+ years serving AB Road. Free site visit. Call 9827348796."
  additionalSchemas={[breadcrumbSchema, localSchema, faqSchema]}
>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">AB Road, Indore</p>
      <h1>Carpenter in AB Road, Indore</h1>
      <div class="gold-line"></div>
      <p class="page-hero-sub">VS Furnitures has been serving AB Road for 30+ years — modular kitchens, wardrobes, office furniture, TV units, and custom carpentry. Free site visit. Call 9827348796.</p>
      <div class="hero-btns">
        <a href="tel:+919827348796" class="btn btn-gold">Call 9827348796</a>
        <a href="https://wa.me/919977250002?text=Hi%20VS%20Furnitures%2C%20I%20need%20a%20carpenter%20in%20AB%20Road%2C%20Indore.%20Can%20I%20get%20a%20free%20site%20visit%3F" target="_blank" rel="noopener" class="btn btn-outline">WhatsApp Us</a>
      </div>
    </div>
  </section>

  <section class="section services-section">
    <div class="container">
      <p class="eyebrow">What We Do on AB Road</p>
      <h2>All carpentry and furniture services on AB Road</h2>
      <div class="gold-line"></div>
      <div class="services-grid reveal">
        {services.map(s => (
          <a href={s.href} class="service-card">
            <span class="arrow">→</span>
            <span>{s.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section reviews-section texture-bg">
    <div class="container">
      <p class="eyebrow">From AB Road Clients</p>
      <h2>What AB Road residents say</h2>
      <div class="gold-line"></div>
      <div class="reviews-grid reveal">
        {reviews.map(r => (
          <div class="review-card">
            <div class="review-stars">{'★'.repeat(r.stars)}</div>
            <p class="review-text">"{r.text}"</p>
            <div class="review-footer">
              <div class="reviewer-avatar">{r.name.charAt(0)}</div>
              <div>
                <p class="reviewer-name">{r.name}</p>
                <p class="reviewer-meta">{r.area} · {r.service}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section area-section">
    <div class="container area-inner">
      <p class="eyebrow">Serving AB Road</p>
      <h2>Your local carpenter on AB Road</h2>
      <div class="gold-line"></div>
      <p>AB Road (Agra-Bombay Road) is Indore's primary commercial and residential corridor — home to large apartment complexes, commercial offices, showrooms, and some of the city's most premium residential addresses. We handle both residential and commercial projects along and off AB Road, including home kitchens and wardrobes as well as office furniture fit-outs for offices in the area.</p>
      <p class="mt">We have completed office furniture projects for businesses based near Apollo DB City, Orbit Mall, and the commercial stretches of AB Road. For residential clients, modular kitchens and living room TV units are our most frequent jobs in this corridor.</p>
      <div class="cta-inline mt">
        <a href="tel:+919827348796" class="btn btn-primary">Call for Free Site Visit</a>
        <a href="https://wa.me/919977250002?text=Hi%20VS%20Furnitures%2C%20I%20need%20a%20carpenter%20in%20AB%20Road%2C%20Indore." target="_blank" rel="noopener" class="btn btn-outline-dark">WhatsApp Us</a>
      </div>
    </div>
  </section>

  <section class="section faq-section">
    <div class="container faq-inner">
      <p class="eyebrow">Common Questions</p>
      <h2>FAQs — Carpenter on AB Road</h2>
      <div class="gold-line"></div>
      <div class="faq-list">
        <details class="faq-item">
          <summary>Do you cover both residential and office properties on AB Road?</summary>
          <p>Yes — AB Road has a mix of residential apartments, independent bungalows, and commercial properties. We handle both residential furniture (kitchens, wardrobes, living room) and office furniture (workstations, reception counters, conference tables) across the full length of AB Road.</p>
        </details>
        <details class="faq-item">
          <summary>Can you build custom office furniture for businesses on AB Road?</summary>
          <p>Absolutely. We regularly build office workstations, reception counters, conference tables, and storage cabinets for small offices and businesses along AB Road. Work is built to your office's exact dimensions, and we can usually complete a small office fit-out in 10 to 14 days.</p>
        </details>
        <details class="faq-item">
          <summary>Which residential colonies on and around AB Road do you serve?</summary>
          <p>We serve all residential areas on and adjacent to AB Road — Nipaniya, Mahalaxmi Nagar, Scheme 54, Vijay Nagar (AB Road side), Sindhi Colony, County Walk, and all the apartment buildings and bungalows along the AB Road corridor.</p>
        </details>
        <details class="faq-item">
          <summary>How quickly can you visit for a site visit on AB Road?</summary>
          <p>We can typically schedule a free site visit on AB Road within 24 hours. For urgent repair calls, same-day or next-morning visits are usually possible. Call 9827348796 to confirm availability.</p>
        </details>
        <details class="faq-item">
          <summary>Do you handle furniture work in high-rise apartments on AB Road?</summary>
          <p>Yes — we work in high-rise buildings across AB Road including gated societies with security check-in. We are comfortable with lift access, working within society timings, and managing materials in multi-floor buildings.</p>
        </details>
      </div>
    </div>
  </section>

  <CTABand heading="Need a carpenter on AB Road?" sub="Free site visit anywhere on AB Road, Indore. Call or WhatsApp — we respond fast." />
</BaseLayout>

<style>
.page-hero { background: var(--navy-deep); padding: 96px 0 64px; text-align: center; }
.page-hero h1 { color: var(--white); font-size: clamp(2rem,5vw,3rem); }
.page-hero .eyebrow { display: block; }
.page-hero .gold-line { margin: 1rem auto 1.5rem; }
.page-hero-sub { color: rgba(255,255,255,0.75); max-width: 580px; margin: 0 auto 2rem; font-size: 1.05rem; }
.hero-btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
.services-grid { display: grid; grid-template-columns: repeat(5,1fr); gap: 0.75rem; margin-top: 1.5rem; }
.service-card { display: flex; align-items: center; gap: 0.5rem; background: var(--white); border: 1px solid rgba(16,37,66,0.1); border-radius: var(--radius); padding: 0.9rem 1rem; text-decoration: none; font-size: 0.88rem; font-weight: 600; color: var(--navy); transition: border-color 0.2s, box-shadow 0.2s; }
.service-card:hover { border-color: var(--gold); box-shadow: var(--shadow); }
.arrow { color: var(--gold); font-weight: 700; flex-shrink: 0; }
.reviews-section { background: var(--paper); }
.reviews-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 1.25rem; margin-top: 1rem; }
.review-card { background: var(--white); border: 1px solid rgba(16,37,66,0.07); border-radius: var(--radius); padding: 1.4rem; box-shadow: var(--shadow); display: flex; flex-direction: column; gap: 0.75rem; }
.review-stars { color: var(--gold); font-size: 0.95rem; }
.review-text { font-size: 0.87rem; color: var(--ink); line-height: 1.6; flex: 1; font-style: italic; }
.review-footer { display: flex; gap: 0.75rem; align-items: center; padding-top: 0.75rem; border-top: 1px solid rgba(16,37,66,0.06); }
.reviewer-avatar { width: 36px; height: 36px; border-radius: 50%; background: var(--navy); color: var(--gold); font-family: var(--font-head); font-size: 1rem; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.reviewer-name { font-size: 0.85rem; font-weight: 700; color: var(--navy); }
.reviewer-meta { font-size: 0.72rem; color: var(--muted); margin-top: 0.1rem; }
.area-section { background: var(--white); }
.area-inner { max-width: 760px; }
.area-inner p { color: var(--muted); line-height: 1.75; font-size: 0.95rem; }
.mt { margin-top: 1rem; }
.cta-inline { display: flex; gap: 1rem; flex-wrap: wrap; }
.btn-outline-dark { background: transparent; border: 2px solid var(--navy); color: var(--navy); padding: 0.75rem 1.75rem; border-radius: var(--radius); font-weight: 700; text-decoration: none; font-size: 0.9rem; }
.btn-outline-dark:hover { background: var(--navy); color: var(--white); }
.faq-section { background: var(--paper); }
.faq-inner { max-width: 760px; }
.faq-list { margin-top: 1.5rem; display: flex; flex-direction: column; gap: 0.75rem; }
.faq-item { background: var(--white); border: 1px solid rgba(16,37,66,0.1); border-radius: var(--radius); overflow: hidden; }
.faq-item summary { padding: 1rem 1.25rem; font-weight: 700; font-size: 0.95rem; color: var(--navy); cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; }
.faq-item summary::after { content: '+'; color: var(--gold); font-size: 1.25rem; font-weight: 400; flex-shrink: 0; margin-left: 1rem; }
.faq-item[open] summary::after { content: '−'; }
.faq-item p { padding: 0 1.25rem 1rem; color: var(--muted); font-size: 0.9rem; line-height: 1.7; margin: 0; }
@media (max-width: 900px) { .services-grid { grid-template-columns: repeat(3,1fr); } }
@media (max-width: 600px) { .services-grid { grid-template-columns: repeat(2,1fr); } .reviews-grid { grid-template-columns: 1fr; } }
</style>
