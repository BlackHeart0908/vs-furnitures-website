---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABand from '../components/CTABand.astro';

const area = 'Annapurna';
const areaSlug = 'annapurna';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type":"ListItem","position":1,"name":"Home","item":"https://vsfurnitures.in"},
    {"@type":"ListItem","position":2,"name":"Carpenter in Annapurna","item":`https://vsfurnitures.in/carpenter-${areaSlug}-indore/`}
  ]
};

const localSchema = {
  "@context": "https://schema.org",
  "@type": "Carpenter",
  "@id": `https://vsfurnitures.in/carpenter-${areaSlug}-indore/#carpenter`,
  "name": "Carpenter. Vs Furniture & Home Solution",
  "url": "https://vsfurnitures.in",
  "telephone": "+919827348796",
  "areaServed": `${area}, Indore`
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Which parts of Annapurna do you cover?",
      "acceptedAnswer": {"@type": "Answer", "text": "We cover all of Annapurna including Annapurna Road, Saikripa Colony, Annapurna Chowk, and neighbouring areas like Lasudia Mori and Rajendra Nagar. Free site visit is available across the entire area."}
    },
    {
      "@type": "Question",
      "name": "What type of homes do you typically work in in Annapurna?",
      "acceptedAnswer": {"@type": "Answer", "text": "Annapurna has a good mix of older independent houses and newer apartment buildings. We work in both — fitting new modular kitchens and wardrobes in new apartments, and also restoring and upgrading older furniture in independent homes."}
    },
    {
      "@type": "Question",
      "name": "How long does a modular kitchen take to complete in Annapurna?",
      "acceptedAnswer": {"@type": "Answer", "text": "A standard modular kitchen in Annapurna takes approximately 3 to 4 weeks from the free site visit to final installation. This includes design finalisation, fabrication, and fitting. We give you a firm timeline upfront before starting."}
    },
    {
      "@type": "Question",
      "name": "Can you build custom office furniture for small businesses in Annapurna?",
      "acceptedAnswer": {"@type": "Answer", "text": "Yes — we regularly build office workstations, reception counters, storage cabinets, and conference tables for small offices and home offices in Annapurna. All work is built to your exact office dimensions and finished to a professional standard."}
    },
    {
      "@type": "Question",
      "name": "Can you restore or repair older wooden furniture in Annapurna homes?",
      "acceptedAnswer": {"@type": "Answer", "text": "Yes — furniture restoration and repair is a service we offer across Annapurna. Whether it is a vintage almirah, an old dining table, loose joints, broken shutters, or dull polish, we assess the piece and restore it. First repair gets 10% off."}
    }
  ]
};

const services = [
  { name: 'Modular Kitchen', href: '/services/modular-kitchen' },
  { name: 'Wardrobes & Bedroom', href: '/services/wardrobes-bedroom' },
  { name: 'Living Room & TV Units', href: '/services/living-room' },
  { name: 'Office Furniture', href: '/services/office-furniture' },
  { name: 'Furniture Repair & Polishing', href: '/services/furniture-repair' },
  { name: 'Custom Carpentry', href: '/services/custom-carpentry' },
  { name: 'False Ceiling & Paneling', href: '/services/false-ceiling' },
  { name: 'Furniture Assembly', href: '/services/furniture-assembly' },
  { name: 'Old Furniture Restoration', href: '/services/furniture-restoration' },
  { name: 'Door & Window Frames', href: '/services/door-window-frames' },
];

const reviews = [
  {
    name: 'Neha Chouhan', stars: 5, service: 'Modular Kitchen', area: 'Annapurna',
    text: 'Best modular kitchen experience. They came for a free site visit, suggested a nice L-shaped layout for our small kitchen, and executed it perfectly. Very happy.'
  },
  {
    name: 'Mohit Srivastava', stars: 5, service: 'Office Furniture', area: 'Annapurna',
    text: 'Got 6 workstations and a conference table made for our small office. Everything built to size, within budget, and delivered before the deadline. Very professional.'
  },
];
---
<BaseLayout
  title="Carpenter in Annapurna Indore | VS Furnitures"
  description="Carpenter in Annapurna, Indore — VS Furnitures. Modular kitchens, wardrobes, furniture repair and custom carpentry. 30+ years serving Annapurna. Free site visit. Call 9827348796."
  additionalSchemas={[breadcrumbSchema, localSchema, faqSchema]}
>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Annapurna, Indore</p>
      <h1>Carpenter in Annapurna, Indore</h1>
      <div class="gold-line"></div>
      <p class="page-hero-sub">VS Furnitures has been serving Annapurna for 30+ years — modular kitchens, wardrobes, office furniture, TV units, and custom carpentry. Free site visit. Call 9827348796.</p>
      <div class="hero-btns">
        <a href="tel:+919827348796" class="btn btn-gold">Call 9827348796</a>
        <a href="https://wa.me/919977250002?text=Hi%20VS%20Furnitures%2C%20I%20need%20a%20carpenter%20in%20Annapurna%2C%20Indore.%20Can%20I%20get%20a%20free%20site%20visit%3F" target="_blank" rel="noopener" class="btn btn-outline">WhatsApp Us</a>
      </div>
    </div>
  </section>

  <section class="section services-section">
    <div class="container">
      <p class="eyebrow">What We Do in Annapurna</p>
      <h2>All carpentry and furniture services in Annapurna</h2>
      <div class="gold-line"></div>
      <div class="services-grid reveal">
        {services.map(s => (
          <a href={s.href} class="service-card">
            <span class="arrow">→</span>
            <span>{s.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section reviews-section texture-bg">
    <div class="container">
      <p class="eyebrow">From Annapurna Clients</p>
      <h2>What Annapurna residents say</h2>
      <div class="gold-line"></div>
      <div class="reviews-grid reveal">
        {reviews.map(r => (
          <div class="review-card">
            <div class="review-stars">{'★'.repeat(r.stars)}</div>
            <p class="review-text">"{r.text}"</p>
            <div class="review-footer">
              <div class="reviewer-avatar">{r.name.charAt(0)}</div>
              <div>
                <p class="reviewer-name">{r.name}</p>
                <p class="reviewer-meta">{r.area} · {r.service}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section area-section">
    <div class="container area-inner">
      <p class="eyebrow">Serving Annapurna</p>
      <h2>Your local carpenter in Annapurna</h2>
      <div class="gold-line"></div>
      <p>Annapurna is one of south Indore's established residential neighbourhoods — a well-connected area with a mix of independent houses, small apartment buildings, and some commercial activity. We work across Annapurna regularly, handling everything from single-room furniture jobs to complete home furnishing projects.</p>
      <p class="mt">The area has a good number of small and home-based offices, which is why we see strong demand for both residential carpentry (kitchens and wardrobes) and commercial office furniture in Annapurna. Our team can visit the same day for urgent repair work or schedule a free site visit for a new project.</p>
      <div class="cta-inline mt">
        <a href="tel:+919827348796" class="btn btn-primary">Call for Free Site Visit</a>
        <a href="https://wa.me/919977250002?text=Hi%20VS%20Furnitures%2C%20I%20need%20a%20carpenter%20in%20Annapurna%2C%20Indore." target="_blank" rel="noopener" class="btn btn-outline-dark">WhatsApp Us</a>
      </div>
      <div class="map-embed mt">
        <iframe
          title="Carpenter. Vs Furniture & Home Solution — Nanda Nagar, Indore"
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3859.127454644361!2d75.87291777372995!3d22.745401058348516!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3962fdde7e9f9a6b%3A0x675cdfdf3871f201!2sCarpenter.%20Vs%20Furniture%20%26%20Home%20Solution!5e0!3m2!1sen!2sin!4v1782846801099!5m2!1sen!2sin"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="strict-origin-when-cross-origin"
        ></iframe>
      </div>
    </div>
  </section>

  <section class="section faq-section">
    <div class="container faq-inner">
      <p class="eyebrow">Common Questions</p>
      <h2>FAQs — Carpenter in Annapurna</h2>
      <div class="gold-line"></div>
      <div class="faq-list">
        <details class="faq-item">
          <summary>Which parts of Annapurna do you cover?</summary>
          <p>We cover all of Annapurna including Annapurna Road, Saikripa Colony, Annapurna Chowk, and neighbouring areas like Lasudia Mori and Rajendra Nagar. Free site visit is available across the entire area.</p>
        </details>
        <details class="faq-item">
          <summary>What type of homes do you typically work in in Annapurna?</summary>
          <p>Annapurna has a good mix of older independent houses and newer apartment buildings. We work in both — fitting new modular kitchens and wardrobes in new apartments, and also restoring and upgrading older furniture in independent homes.</p>
        </details>
        <details class="faq-item">
          <summary>How long does a modular kitchen take to complete in Annapurna?</summary>
          <p>A standard modular kitchen in Annapurna takes approximately 3 to 4 weeks from the free site visit to final installation. This includes design finalisation, fabrication, and fitting. We give you a firm timeline upfront before starting.</p>
        </details>
        <details class="faq-item">
          <summary>Can you build custom office furniture for small businesses in Annapurna?</summary>
          <p>Yes — we regularly build office workstations, reception counters, storage cabinets, and conference tables for small offices and home offices in Annapurna. All work is built to your exact office dimensions and finished to a professional standard.</p>
        </details>
        <details class="faq-item">
          <summary>Can you restore or repair older wooden furniture in Annapurna homes?</summary>
          <p>Yes — furniture restoration and repair is a service we offer across Annapurna. Whether it is a vintage almirah, an old dining table, loose joints, broken shutters, or dull polish, we assess the piece and restore it. First repair gets 10% off.</p>
        </details>
      </div>
    </div>
  </section>

  <CTABand heading="Need a carpenter in Annapurna?" sub="Free site visit anywhere in Annapurna, Indore. Call or WhatsApp — we respond fast." />
</BaseLayout>

<style>
.page-hero { background: var(--navy-deep); padding: 96px 0 64px; text-align: center; }
.page-hero h1 { color: var(--white); font-size: clamp(2rem,5vw,3rem); }
.page-hero .eyebrow { display: block; }
.page-hero .gold-line { margin: 1rem auto 1.5rem; }
.page-hero-sub { color: rgba(255,255,255,0.75); max-width: 580px; margin: 0 auto 2rem; font-size: 1.05rem; }
.hero-btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
.services-grid { display: grid; grid-template-columns: repeat(5,1fr); gap: 0.75rem; margin-top: 1.5rem; }
.service-card { display: flex; align-items: center; gap: 0.5rem; background: var(--white); border: 1px solid rgba(16,37,66,0.1); border-radius: var(--radius); padding: 0.9rem 1rem; text-decoration: none; font-size: 0.88rem; font-weight: 600; color: var(--navy); transition: border-color 0.2s, box-shadow 0.2s; }
.service-card:hover { border-color: var(--gold); box-shadow: var(--shadow); }
.arrow { color: var(--gold); font-weight: 700; flex-shrink: 0; }
.reviews-section { background: var(--paper); }
.reviews-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 1.25rem; margin-top: 1rem; }
.review-card { background: var(--white); border: 1px solid rgba(16,37,66,0.07); border-radius: var(--radius); padding: 1.4rem; box-shadow: var(--shadow); display: flex; flex-direction: column; gap: 0.75rem; }
.review-stars { color: var(--gold); font-size: 0.95rem; }
.review-text { font-size: 0.87rem; color: var(--ink); line-height: 1.6; flex: 1; font-style: italic; }
.review-footer { display: flex; gap: 0.75rem; align-items: center; padding-top: 0.75rem; border-top: 1px solid rgba(16,37,66,0.06); }
.reviewer-avatar { width: 36px; height: 36px; border-radius: 50%; background: var(--navy); color: var(--gold); font-family: var(--font-head); font-size: 1rem; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.reviewer-name { font-size: 0.85rem; font-weight: 700; color: var(--navy); }
.reviewer-meta { font-size: 0.72rem; color: var(--muted); margin-top: 0.1rem; }
.area-section { background: var(--white); }
.area-inner { max-width: 760px; }
.area-inner p { color: var(--muted); line-height: 1.75; font-size: 0.95rem; }
.mt { margin-top: 1rem; }
.cta-inline { display: flex; gap: 1rem; flex-wrap: wrap; }
.btn-outline-dark { background: transparent; border: 2px solid var(--navy); color: var(--navy); padding: 0.75rem 1.75rem; border-radius: var(--radius); font-weight: 700; text-decoration: none; font-size: 0.9rem; }
.btn-outline-dark:hover { background: var(--navy); color: var(--white); }
.faq-section { background: var(--paper); }
.faq-inner { max-width: 760px; }
.faq-list { margin-top: 1.5rem; display: flex; flex-direction: column; gap: 0.75rem; }
.faq-item { background: var(--white); border: 1px solid rgba(16,37,66,0.1); border-radius: var(--radius); overflow: hidden; }
.faq-item summary { padding: 1rem 1.25rem; font-weight: 700; font-size: 0.95rem; color: var(--navy); cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; }
.faq-item summary::after { content: '+'; color: var(--gold); font-size: 1.25rem; font-weight: 400; flex-shrink: 0; margin-left: 1rem; }
.faq-item[open] summary::after { content: '−'; }
.faq-item p { padding: 0 1.25rem 1rem; color: var(--muted); font-size: 0.9rem; line-height: 1.7; margin: 0; }
@media (max-width: 900px) { .services-grid { grid-template-columns: repeat(3,1fr); } }
@media (max-width: 600px) { .services-grid { grid-template-columns: repeat(2,1fr); } .reviews-grid { grid-template-columns: 1fr; } }
.map-embed { height: 300px; border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow-md); border: 1px solid rgba(16,37,66,0.08); }
@media (max-width: 600px) { .map-embed { height: 220px; } }
</style>
