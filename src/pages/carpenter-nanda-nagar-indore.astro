---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABand from '../components/CTABand.astro';

const area = 'Nanda Nagar';
const areaSlug = 'nanda-nagar';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type":"ListItem","position":1,"name":"Home","item":"https://vsfurnitures.in"},
    {"@type":"ListItem","position":2,"name":"Carpenter in Nanda Nagar","item":`https://vsfurnitures.in/carpenter-${areaSlug}-indore/`}
  ]
};

const localSchema = {
  "@context": "https://schema.org",
  "@type": "Carpenter",
  "@id": `https://vsfurnitures.in/carpenter-${areaSlug}-indore/#carpenter`,
  "name": "Carpenter. Vs Furniture & Home Solution",
  "url": "https://vsfurnitures.in",
  "telephone": "+919827348796",
  "areaServed": `${area}, Indore`
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Since you are based in Nanda Nagar, how quickly can you send someone for a repair?",
      "acceptedAnswer": {"@type": "Answer", "text": "We are based right here in Nanda Nagar near ESIC Hospital. For repair calls we can often reach you the same day. For new projects we typically schedule a free site visit within a few hours of your call — no waiting days for a contractor to travel from another part of Indore."}
    },
    {
      "@type": "Question",
      "name": "Do you serve the lanes near ESIC Hospital, Nanda Nagar Square, and Nanda Nagar Chowk?",
      "acceptedAnswer": {"@type": "Answer", "text": "Yes — we have worked in virtually every lane of Nanda Nagar over the past 30 years. ESIC Hospital area, Nanda Nagar Square, Gali No. 24, and the surrounding colonies are all within our immediate service area."}
    },
    {
      "@type": "Question",
      "name": "What are the most popular services in Nanda Nagar?",
      "acceptedAnswer": {"@type": "Answer", "text": "Modular kitchens, wardrobes, false ceilings, and furniture repair and polishing are our most requested services in Nanda Nagar. We also get frequent calls for custom carpentry — pooja mandirs, display units, study desks, and TV panels."}
    },
    {
      "@type": "Question",
      "name": "Can you do emergency furniture repairs in Nanda Nagar?",
      "acceptedAnswer": {"@type": "Answer", "text": "Yes — for urgent repairs like broken hinges, drawers that won't close, or joint repairs, we can usually come the same day since we are based locally. Call 9827348796 and explain the urgency — we prioritise local Nanda Nagar calls."}
    },
    {
      "@type": "Question",
      "name": "What is the starting price for a modular kitchen in Nanda Nagar?",
      "acceptedAnswer": {"@type": "Answer", "text": "Our modular kitchens start from ₹39,990. A complete L-shaped kitchen for a standard Nanda Nagar flat typically costs ₹1,20,000 to ₹3,00,000 depending on size and materials. We will give you an exact price after the free site visit — no hidden charges."}
    }
  ]
};

const services = [
  { name: 'Modular Kitchen', href: '/services/modular-kitchen' },
  { name: 'Wardrobes & Bedroom', href: '/services/wardrobes-bedroom' },
  { name: 'Living Room & TV Units', href: '/services/living-room' },
  { name: 'Office Furniture', href: '/services/office-furniture' },
  { name: 'Furniture Repair & Polishing', href: '/services/furniture-repair' },
  { name: 'Custom Carpentry', href: '/services/custom-carpentry' },
  { name: 'False Ceiling & Paneling', href: '/services/false-ceiling' },
  { name: 'Furniture Assembly', href: '/services/furniture-assembly' },
  { name: 'Old Furniture Restoration', href: '/services/furniture-restoration' },
  { name: 'Door & Window Frames', href: '/services/door-window-frames' },
];

const reviews = [
  {
    name: 'Rajesh Patel', stars: 5, service: 'Custom Carpentry', area: 'Nanda Nagar',
    text: 'Wanted a custom bookshelf with a study desk for my son\'s room. They made exactly what I described. Good wood quality and neat joinery. Will definitely call again.'
  },
  {
    name: 'Sarita Trivedi', stars: 5, service: 'False Ceiling', area: 'Nanda Nagar',
    text: 'POP false ceiling with lighting cutouts in bedroom and living room. Very clean execution. The crew was disciplined and cleaned up everything before leaving.'
  },
];
---
<BaseLayout
  title="Carpenter in Nanda Nagar Indore | VS Furnitures"
  description="Carpenter in Nanda Nagar, Indore — VS Furnitures. Modular kitchens, wardrobes, furniture repair and custom carpentry. 30+ years serving Nanda Nagar. Free site visit. Call 9827348796."
  additionalSchemas={[breadcrumbSchema, localSchema, faqSchema]}
>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Nanda Nagar, Indore</p>
      <h1>Carpenter in Nanda Nagar, Indore</h1>
      <div class="gold-line"></div>
      <p class="page-hero-sub">VS Furnitures is based in Nanda Nagar — we serve the area daily. Modular kitchens, wardrobes, false ceilings, custom carpentry, and repairs. Free site visit. Call 9827348796.</p>
      <div class="hero-btns">
        <a href="tel:+919827348796" class="btn btn-gold">Call 9827348796</a>
        <a href="https://wa.me/919977250002?text=Hi%20VS%20Furnitures%2C%20I%20need%20a%20carpenter%20in%20Nanda%20Nagar%2C%20Indore.%20Can%20I%20get%20a%20free%20site%20visit%3F" target="_blank" rel="noopener" class="btn btn-outline">WhatsApp Us</a>
      </div>
    </div>
  </section>

  <section class="section services-section">
    <div class="container">
      <p class="eyebrow">What We Do in Nanda Nagar</p>
      <h2>All carpentry and furniture services in Nanda Nagar</h2>
      <div class="gold-line"></div>
      <div class="services-grid reveal">
        {services.map(s => (
          <a href={s.href} class="service-card">
            <span class="arrow">→</span>
            <span>{s.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section reviews-section texture-bg">
    <div class="container">
      <p class="eyebrow">From Nanda Nagar Clients</p>
      <h2>What Nanda Nagar residents say</h2>
      <div class="gold-line"></div>
      <div class="reviews-grid reveal">
        {reviews.map(r => (
          <div class="review-card">
            <div class="review-stars">{'★'.repeat(r.stars)}</div>
            <p class="review-text">"{r.text}"</p>
            <div class="review-footer">
              <div class="reviewer-avatar">{r.name.charAt(0)}</div>
              <div>
                <p class="reviewer-name">{r.name}</p>
                <p class="reviewer-meta">{r.area} · {r.service}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section area-section">
    <div class="container area-inner">
      <p class="eyebrow">Based in Nanda Nagar</p>
      <h2>VS Furnitures — your neighbour in Nanda Nagar</h2>
      <div class="gold-line"></div>
      <p>VS Furnitures is based in Nanda Nagar, near Karmachari Rajya Beema Hospital. This means we are on your doorstep — faster response times, no travel delays, and we genuinely know the neighbourhood. We have worked in nearly every lane of Nanda Nagar over 30 years and have built kitchens, wardrobes, and false ceilings across the area.</p>
      <p class="mt">Because we are based here, we can often visit the same day for urgent repair calls and start new projects faster than contractors travelling from other parts of Indore. If you need a carpenter in Nanda Nagar, you are calling the right person.</p>
      <div class="cta-inline mt">
        <a href="tel:+919827348796" class="btn btn-primary">Call for Free Site Visit</a>
        <a href="https://wa.me/919977250002?text=Hi%20VS%20Furnitures%2C%20I%20need%20a%20carpenter%20in%20Nanda%20Nagar%2C%20Indore." target="_blank" rel="noopener" class="btn btn-outline-dark">WhatsApp Us</a>
      </div>
    </div>
  </section>

  <section class="section faq-section">
    <div class="container faq-inner">
      <p class="eyebrow">Common Questions</p>
      <h2>FAQs — Carpenter in Nanda Nagar</h2>
      <div class="gold-line"></div>
      <div class="faq-list">
        <details class="faq-item">
          <summary>Since you are based in Nanda Nagar, how quickly can you send someone for a repair?</summary>
          <p>We are based right here in Nanda Nagar near ESIC Hospital. For repair calls we can often reach you the same day. For new projects we typically schedule a free site visit within a few hours of your call — no waiting days for a contractor to travel from another part of Indore.</p>
        </details>
        <details class="faq-item">
          <summary>Do you serve the lanes near ESIC Hospital, Nanda Nagar Square, and Nanda Nagar Chowk?</summary>
          <p>Yes — we have worked in virtually every lane of Nanda Nagar over the past 30 years. ESIC Hospital area, Nanda Nagar Square, Gali No. 24, and the surrounding colonies are all within our immediate service area.</p>
        </details>
        <details class="faq-item">
          <summary>What are the most popular services in Nanda Nagar?</summary>
          <p>Modular kitchens, wardrobes, false ceilings, and furniture repair and polishing are our most requested services in Nanda Nagar. We also get frequent calls for custom carpentry — pooja mandirs, display units, study desks, and TV panels.</p>
        </details>
        <details class="faq-item">
          <summary>Can you do emergency furniture repairs in Nanda Nagar?</summary>
          <p>Yes — for urgent repairs like broken hinges, drawers that won't close, or joint repairs, we can usually come the same day since we are based locally. Call 9827348796 and explain the urgency — we prioritise local Nanda Nagar calls.</p>
        </details>
        <details class="faq-item">
          <summary>What is the starting price for a modular kitchen in Nanda Nagar?</summary>
          <p>Our modular kitchens start from ₹39,990. A complete L-shaped kitchen for a standard Nanda Nagar flat typically costs ₹1,20,000 to ₹3,00,000 depending on size and materials. We will give you an exact price after the free site visit — no hidden charges.</p>
        </details>
      </div>
    </div>
  </section>

  <CTABand heading="Need a carpenter in Nanda Nagar?" sub="We are based right here in Nanda Nagar — fastest response in the area. Call or WhatsApp now." />
</BaseLayout>

<style>
.page-hero { background: var(--navy-deep); padding: 96px 0 64px; text-align: center; }
.page-hero h1 { color: var(--white); font-size: clamp(2rem,5vw,3rem); }
.page-hero .eyebrow { display: block; }
.page-hero .gold-line { margin: 1rem auto 1.5rem; }
.page-hero-sub { color: rgba(255,255,255,0.75); max-width: 580px; margin: 0 auto 2rem; font-size: 1.05rem; }
.hero-btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
.services-grid { display: grid; grid-template-columns: repeat(5,1fr); gap: 0.75rem; margin-top: 1.5rem; }
.service-card { display: flex; align-items: center; gap: 0.5rem; background: var(--white); border: 1px solid rgba(16,37,66,0.1); border-radius: var(--radius); padding: 0.9rem 1rem; text-decoration: none; font-size: 0.88rem; font-weight: 600; color: var(--navy); transition: border-color 0.2s, box-shadow 0.2s; }
.service-card:hover { border-color: var(--gold); box-shadow: var(--shadow); }
.arrow { color: var(--gold); font-weight: 700; flex-shrink: 0; }
.reviews-section { background: var(--paper); }
.reviews-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 1.25rem; margin-top: 1rem; }
.review-card { background: var(--white); border: 1px solid rgba(16,37,66,0.07); border-radius: var(--radius); padding: 1.4rem; box-shadow: var(--shadow); display: flex; flex-direction: column; gap: 0.75rem; }
.review-stars { color: var(--gold); font-size: 0.95rem; }
.review-text { font-size: 0.87rem; color: var(--ink); line-height: 1.6; flex: 1; font-style: italic; }
.review-footer { display: flex; gap: 0.75rem; align-items: center; padding-top: 0.75rem; border-top: 1px solid rgba(16,37,66,0.06); }
.reviewer-avatar { width: 36px; height: 36px; border-radius: 50%; background: var(--navy); color: var(--gold); font-family: var(--font-head); font-size: 1rem; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.reviewer-name { font-size: 0.85rem; font-weight: 700; color: var(--navy); }
.reviewer-meta { font-size: 0.72rem; color: var(--muted); margin-top: 0.1rem; }
.area-section { background: var(--white); }
.area-inner { max-width: 760px; }
.area-inner p { color: var(--muted); line-height: 1.75; font-size: 0.95rem; }
.mt { margin-top: 1rem; }
.cta-inline { display: flex; gap: 1rem; flex-wrap: wrap; }
.btn-outline-dark { background: transparent; border: 2px solid var(--navy); color: var(--navy); padding: 0.75rem 1.75rem; border-radius: var(--radius); font-weight: 700; text-decoration: none; font-size: 0.9rem; }
.btn-outline-dark:hover { background: var(--navy); color: var(--white); }
.faq-section { background: var(--paper); }
.faq-inner { max-width: 760px; }
.faq-list { margin-top: 1.5rem; display: flex; flex-direction: column; gap: 0.75rem; }
.faq-item { background: var(--white); border: 1px solid rgba(16,37,66,0.1); border-radius: var(--radius); overflow: hidden; }
.faq-item summary { padding: 1rem 1.25rem; font-weight: 700; font-size: 0.95rem; color: var(--navy); cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; }
.faq-item summary::after { content: '+'; color: var(--gold); font-size: 1.25rem; font-weight: 400; flex-shrink: 0; margin-left: 1rem; }
.faq-item[open] summary::after { content: '−'; }
.faq-item p { padding: 0 1.25rem 1rem; color: var(--muted); font-size: 0.9rem; line-height: 1.7; margin: 0; }
@media (max-width: 900px) { .services-grid { grid-template-columns: repeat(3,1fr); } }
@media (max-width: 600px) { .services-grid { grid-template-columns: repeat(2,1fr); } .reviews-grid { grid-template-columns: 1fr; } }
</style>
