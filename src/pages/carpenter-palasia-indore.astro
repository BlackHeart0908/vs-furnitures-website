---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABand from '../components/CTABand.astro';

const area = 'Palasia';
const areaSlug = 'palasia';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type":"ListItem","position":1,"name":"Home","item":"https://vsfurnitures.in"},
    {"@type":"ListItem","position":2,"name":"Carpenter in Palasia","item":`https://vsfurnitures.in/carpenter-${areaSlug}-indore/`}
  ]
};

const localSchema = {
  "@context": "https://schema.org",
  "@type": "Carpenter",
  "@id": `https://vsfurnitures.in/carpenter-${areaSlug}-indore/#carpenter`,
  "name": "Carpenter. Vs Furniture & Home Solution",
  "url": "https://vsfurnitures.in",
  "telephone": "+919827348796",
  "areaServed": `${area}, Indore`
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "My home in Old Palasia has vintage wooden furniture — can you restore it?",
      "acceptedAnswer": {"@type": "Answer", "text": "Yes — furniture restoration is one of our specialties. We repair joints, re-polish surfaces, replace broken hardware, and restore older wooden pieces to excellent condition. We have restored many traditional wooden almirahs and dining sets from older Palasia homes."}
    },
    {
      "@type": "Question",
      "name": "Can you fit a modular kitchen in a compact space in a Palasia flat?",
      "acceptedAnswer": {"@type": "Answer", "text": "Absolutely. Many Palasia flats have smaller, compact kitchens — we specialise in L-shaped and straight modular kitchen layouts that maximise storage in limited space. During the free site visit we measure and suggest the most efficient layout for your specific kitchen."}
    },
    {
      "@type": "Question",
      "name": "How long does it take to complete a wardrobe in a Palasia apartment?",
      "acceptedAnswer": {"@type": "Answer", "text": "A standard floor-to-ceiling wardrobe typically takes 7 to 10 days from measurement to installation. Custom wardrobes with sliding doors or mirror panels may take up to 2 weeks. We confirm the timeline before starting."}
    },
    {
      "@type": "Question",
      "name": "Do you cover areas near Palasia Square and Old Palasia?",
      "acceptedAnswer": {"@type": "Answer", "text": "Yes — we cover all of Palasia including Old Palasia, Palasia Square, Patrakar Colony, and the apartment buildings along the main Palasia stretch. Free site visit is available across the entire area."}
    },
    {
      "@type": "Question",
      "name": "What is your starting price for a modular kitchen in Palasia?",
      "acceptedAnswer": {"@type": "Answer", "text": "Modular kitchens start from ₹39,990. For a standard Palasia flat kitchen (L-shaped, approximately 8 by 6 feet), the typical cost is ₹1,20,000 to ₹2,50,000 depending on finish and hardware. Call for a free site visit and exact estimate."}
    }
  ]
};

const services = [
  { name: 'Modular Kitchen', href: '/services/modular-kitchen' },
  { name: 'Wardrobes & Bedroom', href: '/services/wardrobes-bedroom' },
  { name: 'Living Room & TV Units', href: '/services/living-room' },
  { name: 'Office Furniture', href: '/services/office-furniture' },
  { name: 'Furniture Repair & Polishing', href: '/services/furniture-repair' },
  { name: 'Custom Carpentry', href: '/services/custom-carpentry' },
  { name: 'False Ceiling & Paneling', href: '/services/false-ceiling' },
  { name: 'Furniture Assembly', href: '/services/furniture-assembly' },
  { name: 'Old Furniture Restoration', href: '/services/furniture-restoration' },
  { name: 'Door & Window Frames', href: '/services/door-window-frames' },
];

const reviews = [
  {
    name: 'Priya Gupta', stars: 5, service: 'Wardrobe', area: 'Palasia',
    text: 'Needed a floor-to-ceiling wardrobe in our bedroom. They measured, suggested the best layout, and delivered on time. Very clean finish. Will use them again.'
  },
  {
    name: 'Meera Soni', stars: 5, service: 'Modular Kitchen', area: 'Palasia',
    text: 'Third time using VS Furnitures. First my kitchen, then my sister\'s, and now my mother\'s. Every time the quality and service is the same — excellent.'
  },
  {
    name: 'Lalita Verma', stars: 5, service: 'Modular Kitchen', area: 'Palasia',
    text: 'The free site visit was very helpful. They suggested changes to my original plan that saved space and money. Kitchen turned out better than I imagined.'
  },
];
---
<BaseLayout
  title="Carpenter in Palasia Indore | VS Furnitures"
  description="Carpenter in Palasia, Indore — VS Furnitures. Modular kitchens, wardrobes, furniture repair and custom carpentry. 30+ years serving Palasia. Free site visit. Call 9827348796."
  additionalSchemas={[breadcrumbSchema, localSchema, faqSchema]}
>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Palasia, Indore</p>
      <h1>Carpenter in Palasia, Indore</h1>
      <div class="gold-line"></div>
      <p class="page-hero-sub">VS Furnitures has been serving Palasia for 30+ years — modular kitchens, wardrobes, TV units, furniture repair, and custom carpentry. Free site visit. Call 9827348796.</p>
      <div class="hero-btns">
        <a href="tel:+919827348796" class="btn btn-gold">Call 9827348796</a>
        <a href="https://wa.me/919977250002?text=Hi%20VS%20Furnitures%2C%20I%20need%20a%20carpenter%20in%20Palasia%2C%20Indore.%20Can%20I%20get%20a%20free%20site%20visit%3F" target="_blank" rel="noopener" class="btn btn-outline">WhatsApp Us</a>
      </div>
    </div>
  </section>

  <section class="section services-section">
    <div class="container">
      <p class="eyebrow">What We Do in Palasia</p>
      <h2>All carpentry and furniture services in Palasia</h2>
      <div class="gold-line"></div>
      <div class="services-grid reveal">
        {services.map(s => (
          <a href={s.href} class="service-card">
            <span class="arrow">→</span>
            <span>{s.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section reviews-section texture-bg">
    <div class="container">
      <p class="eyebrow">From Palasia Clients</p>
      <h2>What Palasia residents say</h2>
      <div class="gold-line"></div>
      <div class="reviews-grid reveal">
        {reviews.map(r => (
          <div class="review-card">
            <div class="review-stars">{'★'.repeat(r.stars)}</div>
            <p class="review-text">"{r.text}"</p>
            <div class="review-footer">
              <div class="reviewer-avatar">{r.name.charAt(0)}</div>
              <div>
                <p class="reviewer-name">{r.name}</p>
                <p class="reviewer-meta">{r.area} · {r.service}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section area-section">
    <div class="container area-inner">
      <p class="eyebrow">Serving Palasia</p>
      <h2>Your local carpenter in Palasia</h2>
      <div class="gold-line"></div>
      <p>Palasia is one of central Indore's most established neighbourhoods — a mix of older independent houses and newer apartment buildings. We have worked extensively across Palasia, including flats near Palasia Square, bungalows in Old Palasia, and apartment buildings along the main road. Our team can reach Palasia quickly for a free site visit.</p>
      <p class="mt">Palasia homes often have compact but efficiently laid-out kitchens. Our most popular work in the area is L-shaped and straight modular kitchens that maximise storage in standard-sized kitchen spaces. We also see high demand for floor-to-ceiling wardrobes and complete bedroom fit-outs from families upgrading older homes.</p>
      <div class="cta-inline mt">
        <a href="tel:+919827348796" class="btn btn-primary">Call for Free Site Visit</a>
        <a href="https://wa.me/919977250002?text=Hi%20VS%20Furnitures%2C%20I%20need%20a%20carpenter%20in%20Palasia%2C%20Indore." target="_blank" rel="noopener" class="btn btn-outline-dark">WhatsApp Us</a>
      </div>
    </div>
  </section>

  <section class="section faq-section">
    <div class="container faq-inner">
      <p class="eyebrow">Common Questions</p>
      <h2>FAQs — Carpenter in Palasia</h2>
      <div class="gold-line"></div>
      <div class="faq-list">
        <details class="faq-item">
          <summary>My home in Old Palasia has vintage wooden furniture — can you restore it?</summary>
          <p>Yes — furniture restoration is one of our specialties. We repair joints, re-polish surfaces, replace broken hardware, and restore older wooden pieces to excellent condition. We have restored many traditional wooden almirahs and dining sets from older Palasia homes.</p>
        </details>
        <details class="faq-item">
          <summary>Can you fit a modular kitchen in a compact space in a Palasia flat?</summary>
          <p>Absolutely. Many Palasia flats have smaller, compact kitchens — we specialise in L-shaped and straight modular kitchen layouts that maximise storage in limited space. During the free site visit we measure and suggest the most efficient layout for your specific kitchen.</p>
        </details>
        <details class="faq-item">
          <summary>How long does it take to complete a wardrobe in a Palasia apartment?</summary>
          <p>A standard floor-to-ceiling wardrobe typically takes 7 to 10 days from measurement to installation. Custom wardrobes with sliding doors or mirror panels may take up to 2 weeks. We confirm the timeline before starting.</p>
        </details>
        <details class="faq-item">
          <summary>Do you cover areas near Palasia Square and Old Palasia?</summary>
          <p>Yes — we cover all of Palasia including Old Palasia, Palasia Square, Patrakar Colony, and the apartment buildings along the main Palasia stretch. Free site visit is available across the entire area.</p>
        </details>
        <details class="faq-item">
          <summary>What is your starting price for a modular kitchen in Palasia?</summary>
          <p>Modular kitchens start from ₹39,990. For a standard Palasia flat kitchen (L-shaped, approximately 8 by 6 feet), the typical cost is ₹1,20,000 to ₹2,50,000 depending on finish and hardware. Call for a free site visit and exact estimate.</p>
        </details>
      </div>
    </div>
  </section>

  <CTABand heading="Need a carpenter in Palasia?" sub="Free site visit anywhere in Palasia, Indore. Call or WhatsApp — we respond fast." />
</BaseLayout>

<style>
.page-hero { background: var(--navy-deep); padding: 96px 0 64px; text-align: center; }
.page-hero h1 { color: var(--white); font-size: clamp(2rem,5vw,3rem); }
.page-hero .eyebrow { display: block; }
.page-hero .gold-line { margin: 1rem auto 1.5rem; }
.page-hero-sub { color: rgba(255,255,255,0.75); max-width: 580px; margin: 0 auto 2rem; font-size: 1.05rem; }
.hero-btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
.services-grid { display: grid; grid-template-columns: repeat(5,1fr); gap: 0.75rem; margin-top: 1.5rem; }
.service-card { display: flex; align-items: center; gap: 0.5rem; background: var(--white); border: 1px solid rgba(16,37,66,0.1); border-radius: var(--radius); padding: 0.9rem 1rem; text-decoration: none; font-size: 0.88rem; font-weight: 600; color: var(--navy); transition: border-color 0.2s, box-shadow 0.2s; }
.service-card:hover { border-color: var(--gold); box-shadow: var(--shadow); }
.arrow { color: var(--gold); font-weight: 700; flex-shrink: 0; }
.reviews-section { background: var(--paper); }
.reviews-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.25rem; margin-top: 1rem; }
.review-card { background: var(--white); border: 1px solid rgba(16,37,66,0.07); border-radius: var(--radius); padding: 1.4rem; box-shadow: var(--shadow); display: flex; flex-direction: column; gap: 0.75rem; }
.review-stars { color: var(--gold); font-size: 0.95rem; }
.review-text { font-size: 0.87rem; color: var(--ink); line-height: 1.6; flex: 1; font-style: italic; }
.review-footer { display: flex; gap: 0.75rem; align-items: center; padding-top: 0.75rem; border-top: 1px solid rgba(16,37,66,0.06); }
.reviewer-avatar { width: 36px; height: 36px; border-radius: 50%; background: var(--navy); color: var(--gold); font-family: var(--font-head); font-size: 1rem; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.reviewer-name { font-size: 0.85rem; font-weight: 700; color: var(--navy); }
.reviewer-meta { font-size: 0.72rem; color: var(--muted); margin-top: 0.1rem; }
.area-section { background: var(--white); }
.area-inner { max-width: 760px; }
.area-inner p { color: var(--muted); line-height: 1.75; font-size: 0.95rem; }
.mt { margin-top: 1rem; }
.cta-inline { display: flex; gap: 1rem; flex-wrap: wrap; }
.btn-outline-dark { background: transparent; border: 2px solid var(--navy); color: var(--navy); padding: 0.75rem 1.75rem; border-radius: var(--radius); font-weight: 700; text-decoration: none; font-size: 0.9rem; }
.btn-outline-dark:hover { background: var(--navy); color: var(--white); }
.faq-section { background: var(--paper); }
.faq-inner { max-width: 760px; }
.faq-list { margin-top: 1.5rem; display: flex; flex-direction: column; gap: 0.75rem; }
.faq-item { background: var(--white); border: 1px solid rgba(16,37,66,0.1); border-radius: var(--radius); overflow: hidden; }
.faq-item summary { padding: 1rem 1.25rem; font-weight: 700; font-size: 0.95rem; color: var(--navy); cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; }
.faq-item summary::after { content: '+'; color: var(--gold); font-size: 1.25rem; font-weight: 400; flex-shrink: 0; margin-left: 1rem; }
.faq-item[open] summary::after { content: '−'; }
.faq-item p { padding: 0 1.25rem 1rem; color: var(--muted); font-size: 0.9rem; line-height: 1.7; margin: 0; }
@media (max-width: 900px) { .services-grid { grid-template-columns: repeat(3,1fr); } .reviews-grid { grid-template-columns: 1fr 1fr; } }
@media (max-width: 600px) { .services-grid { grid-template-columns: repeat(2,1fr); } .reviews-grid { grid-template-columns: 1fr; } }
</style>
