---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABand from '../components/CTABand.astro';

const area = 'Vijay Nagar';
const areaSlug = 'vijay-nagar';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type":"ListItem","position":1,"name":"Home","item":"https://vsfurnitures.in"},
    {"@type":"ListItem","position":2,"name":"Carpenter in Vijay Nagar","item":`https://vsfurnitures.in/carpenter-${areaSlug}-indore`}
  ]
};

const localSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": "https://vsfurnitures.in/#business",
  "name": "VS Furnitures",
  "url": "https://vsfurnitures.in",
  "telephone": "+919827348796",
  "areaServed": `${area}, Indore`,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Indore",
    "addressRegion": "Madhya Pradesh",
    "postalCode": "452011",
    "addressCountry": "IN"
  }
};

const services = [
  { name: 'Modular Kitchen', href: '/services/modular-kitchen' },
  { name: 'Wardrobes & Bedroom', href: '/services/wardrobes-bedroom' },
  { name: 'Living Room & TV Units', href: '/services/living-room' },
  { name: 'Office Furniture', href: '/services/office-furniture' },
  { name: 'Furniture Repair & Polishing', href: '/services/furniture-repair' },
  { name: 'Custom Carpentry', href: '/services/custom-carpentry' },
  { name: 'False Ceiling & Paneling', href: '/services/false-ceiling' },
  { name: 'Furniture Assembly', href: '/services/furniture-assembly' },
  { name: 'Old Furniture Restoration', href: '/services/furniture-restoration' },
  { name: 'Door & Window Frames', href: '/services/door-window-frames' },
];

const reviews = [
  {
    name: 'Ravi Sharma',
    stars: 5,
    service: 'Modular Kitchen',
    area: 'Vijay Nagar',
    text: 'Got our modular kitchen done from VS Furnitures. Quality of ply and fittings is excellent. Soft-close shutters still working perfectly after 2 years. Highly recommend.'
  },
  {
    name: 'Geeta Agrawal',
    stars: 5,
    service: 'Custom Carpentry',
    area: 'Vijay Nagar',
    text: 'Wanted a pooja mandir and a display unit for the hall. Both came out beautifully. The detailing on the mandir was especially nice. Very skilled craftsmen.'
  },
  {
    name: 'Suresh Yadav',
    stars: 5,
    service: 'Furniture Restoration',
    area: 'Vijay Nagar',
    text: 'My grandfather\'s old wooden almirah was in bad shape. They restored it beautifully — repaired the joints, polished it, and it looks like an antique showpiece now.'
  },
];
---
<BaseLayout
  title="Carpenter in Vijay Nagar Indore | VS Furnitures"
  description="Carpenter in Vijay Nagar, Indore — VS Furnitures. Modular kitchens, wardrobes, furniture repair and custom carpentry. 30+ years serving Vijay Nagar. Free site visit. Call 9827348796."
  additionalSchemas={[breadcrumbSchema, localSchema]}
>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Vijay Nagar, Indore</p>
      <h1>Carpenter in Vijay Nagar, Indore</h1>
      <div class="gold-line"></div>
      <p class="page-hero-sub">VS Furnitures has been serving Vijay Nagar for 30+ years — modular kitchens, wardrobes, TV units, furniture repair, and custom carpentry. Free site visit. Call 9827348796.</p>
      <div class="hero-btns">
        <a href="tel:+919827348796" class="btn btn-gold">Call 9827348796</a>
        <a href="https://wa.me/919977250002?text=Hi%20VS%20Furnitures%2C%20I%20need%20a%20carpenter%20in%20Vijay%20Nagar%2C%20Indore.%20Can%20I%20get%20a%20free%20site%20visit%3F" target="_blank" rel="noopener" class="btn btn-outline">WhatsApp Us</a>
      </div>
    </div>
  </section>

  <section class="section services-section">
    <div class="container">
      <p class="eyebrow">What We Do in Vijay Nagar</p>
      <h2>All carpentry and furniture services in Vijay Nagar</h2>
      <div class="gold-line"></div>
      <div class="services-grid reveal">
        {services.map(s => (
          <a href={s.href} class="service-card">
            <span class="arrow">→</span>
            <span>{s.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section reviews-section texture-bg">
    <div class="container">
      <p class="eyebrow">From Vijay Nagar Clients</p>
      <h2>What Vijay Nagar residents say</h2>
      <div class="gold-line"></div>
      <div class="reviews-grid reveal">
        {reviews.map(r => (
          <div class="review-card">
            <div class="review-stars">{'★'.repeat(r.stars)}</div>
            <p class="review-text">"{r.text}"</p>
            <div class="review-footer">
              <div class="reviewer-avatar">{r.name.charAt(0)}</div>
              <div>
                <p class="reviewer-name">{r.name}</p>
                <p class="reviewer-meta">{r.area} · {r.service}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section area-section">
    <div class="container area-inner">
      <p class="eyebrow">Serving Vijay Nagar</p>
      <h2>Your local carpenter in Vijay Nagar</h2>
      <div class="gold-line"></div>
      <p>We regularly work across Vijay Nagar — whether it is a new flat in Omex City, a villa in County Walk, or an older independent house near Vijay Nagar Square. Our team knows the area well and can reach you quickly for a free site visit. Vijay Nagar is one of Indore's most active areas for new home furnishing, and we have completed hundreds of modular kitchens, wardrobes, and full home fit-outs here over the past 30 years.</p>
      <p class="mt">Most Vijay Nagar flats have standard L-shaped or parallel kitchen layouts — we have built dozens of these and know exactly what works. For wardrobes, Vijay Nagar apartments typically need floor-to-ceiling sliding wardrobes to make the most of limited bedroom space.</p>
      <div class="cta-inline mt">
        <a href="tel:+919827348796" class="btn btn-primary">Call for Free Site Visit</a>
        <a href="https://wa.me/919977250002?text=Hi%20VS%20Furnitures%2C%20I%20need%20a%20carpenter%20in%20Vijay%20Nagar%2C%20Indore." target="_blank" rel="noopener" class="btn btn-outline-dark">WhatsApp Us</a>
      </div>
    </div>
  </section>

  <CTABand heading="Need a carpenter in Vijay Nagar?" sub="Free site visit anywhere in Vijay Nagar, Indore. Call or WhatsApp — we respond fast." />
</BaseLayout>

<style>
.page-hero { background: var(--navy-deep); padding: 96px 0 64px; text-align: center; }
.page-hero h1 { color: var(--white); font-size: clamp(2rem,5vw,3rem); }
.page-hero .eyebrow { display: block; }
.page-hero .gold-line { margin: 1rem auto 1.5rem; }
.page-hero-sub { color: rgba(255,255,255,0.75); max-width: 580px; margin: 0 auto 2rem; font-size: 1.05rem; }
.hero-btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
.services-grid { display: grid; grid-template-columns: repeat(5,1fr); gap: 0.75rem; margin-top: 1.5rem; }
.service-card { display: flex; align-items: center; gap: 0.5rem; background: var(--white); border: 1px solid rgba(16,37,66,0.1); border-radius: var(--radius); padding: 0.9rem 1rem; text-decoration: none; font-size: 0.88rem; font-weight: 600; color: var(--navy); transition: border-color 0.2s, box-shadow 0.2s; }
.service-card:hover { border-color: var(--gold); box-shadow: var(--shadow); }
.arrow { color: var(--gold); font-weight: 700; flex-shrink: 0; }
.reviews-section { background: var(--paper); }
.reviews-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.25rem; margin-top: 1rem; }
.review-card { background: var(--white); border: 1px solid rgba(16,37,66,0.07); border-radius: var(--radius); padding: 1.4rem; box-shadow: var(--shadow); display: flex; flex-direction: column; gap: 0.75rem; }
.review-stars { color: var(--gold); font-size: 0.95rem; }
.review-text { font-size: 0.87rem; color: var(--ink); line-height: 1.6; flex: 1; font-style: italic; }
.review-footer { display: flex; gap: 0.75rem; align-items: center; padding-top: 0.75rem; border-top: 1px solid rgba(16,37,66,0.06); }
.reviewer-avatar { width: 36px; height: 36px; border-radius: 50%; background: var(--navy); color: var(--gold); font-family: var(--font-head); font-size: 1rem; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.reviewer-name { font-size: 0.85rem; font-weight: 700; color: var(--navy); }
.reviewer-meta { font-size: 0.72rem; color: var(--muted); margin-top: 0.1rem; }
.area-section { background: var(--white); }
.area-inner { max-width: 760px; }
.area-inner p { color: var(--muted); line-height: 1.75; font-size: 0.95rem; }
.mt { margin-top: 1rem; }
.cta-inline { display: flex; gap: 1rem; flex-wrap: wrap; }
.btn-outline-dark { background: transparent; border: 2px solid var(--navy); color: var(--navy); padding: 0.75rem 1.75rem; border-radius: var(--radius); font-weight: 700; text-decoration: none; font-size: 0.9rem; }
.btn-outline-dark:hover { background: var(--navy); color: var(--white); }
@media (max-width: 900px) { .services-grid { grid-template-columns: repeat(3,1fr); } .reviews-grid { grid-template-columns: 1fr 1fr; } }
@media (max-width: 600px) { .services-grid { grid-template-columns: repeat(2,1fr); } .reviews-grid { grid-template-columns: 1fr; } }
</style>
