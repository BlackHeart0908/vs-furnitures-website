---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABand from '../components/CTABand.astro';
---
<BaseLayout
  title="How We Work | VS Furnitures Indore — Two Ways to Work With Us"
  description="Two ways to work with VS Furnitures — Percentage Basis (you manage material) or With Material (we handle everything). Furniture built at your place. Full transparency. Indore."
>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Process</p>
      <h1>How We Work</h1>
      <div class="gold-line"></div>
      <p class="hero-sub">From your first call to the day you see your finished furniture — here is exactly what happens.</p>
    </div>
  </section>

  <!-- PROCESS STEPS -->
  <section class="section process-section">
    <div class="container">
      <p class="eyebrow">Step by Step</p>
      <h2>From first call to finished furniture</h2>
      <div class="gold-line"></div>
      <div class="steps-track">

        <div class="step reveal">
          <div class="step-num">01</div>
          <div class="step-body">
            <h3>You Call or WhatsApp Us</h3>
            <p>Tell us what you need — a kitchen, a wardrobe, full home interior, or any carpentry work. We are available 9 AM to 8 PM, Monday to Saturday. One call is all it takes.</p>
          </div>
        </div>

        <div class="step reveal">
          <div class="step-num">02</div>
          <div class="step-body">
            <h3>We Visit Your Home — Free Site Visit</h3>
            <p>We come to you, take exact measurements of your space, and listen carefully to what you have in mind. No charge for the site visit. No obligation to proceed.</p>
          </div>
        </div>

        <div class="step reveal">
          <div class="step-num">03</div>
          <div class="step-body">
            <h3>We Shape Your Vision Professionally</h3>
            <p>A rough description, a photo from Pinterest, a sketch on paper — any starting point works. We take your ideas and give them a proper professional form: layout, dimensions, material choices, and finish options.</p>
          </div>
        </div>

        <div class="step reveal">
          <div class="step-num">04</div>
          <div class="step-body">
            <h3>Quotation &amp; Agreement</h3>
            <p>We give you a clear, exact quotation — full transparency on what material will be used and what labour will cost. Then you choose which way you want to work with us.</p>
          </div>
        </div>

        <div class="step reveal">
          <div class="step-num">05</div>
          <div class="step-body">
            <h3>We Build It at Your Place</h3>
            <p>Your furniture is built at your home — not in some distant workshop. You watch it take shape from raw material to the finished piece. No guesswork. No surprises.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- TWO WAYS -->
  <section class="section ways-section texture-bg">
    <div class="container">
      <p class="eyebrow">Two Ways to Work With Us</p>
      <h2>Choose what works for you</h2>
      <div class="gold-line"></div>
      <div class="ways-grid">

        <!-- Percentage Basis -->
        <div class="way-card reveal">
          <div class="way-label">Option 1</div>
          <h3>Percentage Basis</h3>
          <p class="way-sub">You manage the material. We provide the craftsmanship.</p>
          <div class="way-divider"></div>
          <ul class="way-list">
            <li>We guide you exactly on what material to buy and where to source it</li>
            <li>You visit the hardware shops yourself, compare quotations, and purchase the material</li>
            <li>You arrange for the material to be delivered to the site</li>
            <li>We charge <strong>32% over the total material cost</strong> as our labour fee</li>
            <li>You receive our quotation upfront — you know the exact percentage before you agree to anything</li>
          </ul>
          <div class="way-note">
            <strong>Right for you if:</strong> You want hands-on involvement in material selection and are comfortable doing the market visits yourself.
          </div>
        </div>

        <!-- With Material -->
        <div class="way-card way-card--featured reveal">
          <div class="way-label way-label--gold">Option 2 &nbsp;·&nbsp; Most Trusted by Our Clients</div>
          <h3>With Material</h3>
          <p class="way-sub">We handle everything — material sourcing and craftsmanship.</p>
          <div class="way-divider"></div>
          <ul class="way-list">
            <li>We agree on the material quality and your budget upfront</li>
            <li>We use our 30-year market network to source the best material at the right price</li>
            <li><strong>Wood and ply samples come to your home</strong> — you choose the quality without stepping out</li>
            <li><strong>Sunmica catalogue with hundreds of sunmica options</strong> delivered to your door — touch, feel, and compare the textures at home</li>
            <li>We carry full guarantee on the furniture — longevity, quality, and durability</li>
            <li>We tell you exactly how long your furniture will last and what conditions it will withstand</li>
          </ul>
          <div class="way-note way-note--gold">
            <strong>Why clients prefer this:</strong> You do not move a single inch. Every decision is made from the comfort of your home, with real samples and catalogues in your hand — not from a phone screen.
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- TRANSPARENCY HIGHLIGHT -->
  <section class="section transparency-section">
    <div class="container">
      <div class="transparency-block reveal">
        <p class="eyebrow">Our Most Important Promise</p>
        <h2>Your furniture is built at your place.<br /><span class="gold-text">You see every step.</span></h2>
        <div class="gold-line"></div>
        <p class="t-text">
          Many furniture companies and local contractors build your furniture at their workshop or factory and deliver it to you ready-made. Once it arrives, you have no way of knowing what went inside — whether the ply is actually what they quoted, whether the sunmica is genuine, whether the hardware is the brand they promised.
        </p>
        <p class="t-text mt">
          <strong>We build at your place.</strong> You see every sheet of ply go in. You see the hardware being fitted. You watch it grow from raw material to your finished furniture — from scratch to the final touch. There is no room for any substitution, any corner-cutting, any gap between what we promised and what we actually deliver.
        </p>
        <div class="t-compare reveal">
          <div class="t-compare-row t-compare-bad">
            <span class="t-icon">✗</span>
            <p>With ready-made furniture or a workshop contractor — you pay for what they <em>say</em> it is. You can never verify once it's done.</p>
          </div>
          <div class="t-compare-row t-compare-good">
            <span class="t-icon">✓</span>
            <p><strong>With VS Furnitures — you pay for what you can see, touch, and feel. From the first day of build to the last day of its life.</strong></p>
          </div>
        </div>
        <div class="t-badge reveal">
          Full Transparency — No Furniture Company or Local Contractor Can Match This
        </div>
      </div>
    </div>
  </section>

  <!-- OFFER -->
  <section class="section-sm offer-section">
    <div class="container offer-inner">
      <div class="offer-eyebrow">Our Offer</div>
      <h2>Furniture starts from <span class="gold-text">₹39,990</span></h2>
      <p>Quality-built furniture, constructed at your place, with complete transparency — starting at ₹39,990. Call or WhatsApp for a free site visit and exact quotation.</p>
      <div class="offer-btns">
        <a href="tel:+919827348796" class="btn btn-gold">Call for Free Site Visit</a>
        <a href="https://wa.me/919977250002?text=Hi%20VS%20Furnitures%2C%20I%20read%20about%20how%20you%20work%20and%20I%20would%20like%20a%20free%20site%20visit." target="_blank" rel="noopener" class="btn btn-outline">WhatsApp Us</a>
      </div>
    </div>
  </section>

  <CTABand heading="Seen enough to decide?" sub="Call or WhatsApp — we come to your home, take measurements, and give you a clear honest quotation." />
</BaseLayout>

<style>
.page-hero { background: var(--navy-deep); padding: 96px 0 64px; text-align: center; }
.page-hero h1 { color: var(--white); font-size: clamp(2rem,5vw,3rem); }
.page-hero .eyebrow { display: block; }
.page-hero .gold-line { margin: 1rem auto 1.5rem; }
.hero-sub { color: rgba(255,255,255,0.75); max-width: 580px; margin: 0 auto; font-size: 1.05rem; }

/* PROCESS */
.process-section { background: var(--white); }
.steps-track { display: flex; flex-direction: column; gap: 0; margin-top: 1.5rem; max-width: 760px; }
.step { display: grid; grid-template-columns: 72px 1fr; gap: 1.5rem; align-items: start; padding: 1.5rem 0; border-bottom: 1px solid rgba(16,37,66,0.07); }
.step:last-child { border-bottom: none; }
.step-num { font-family: var(--font-head); font-size: 2.2rem; font-weight: 700; color: var(--gold); line-height: 1; padding-top: 0.1rem; }
.step-body h3 { font-size: 1.05rem; color: var(--navy); margin-bottom: 0.4rem; }
.step-body p { font-size: 0.9rem; color: var(--muted); line-height: 1.7; }

/* TWO WAYS */
.ways-section { background: var(--paper); }
.ways-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-top: 0.5rem; }
.way-card { background: var(--white); border: 1px solid rgba(16,37,66,0.1); border-radius: var(--radius); padding: 2rem; box-shadow: var(--shadow); display: flex; flex-direction: column; gap: 1rem; }
.way-card--featured { background: var(--navy); border-color: var(--gold); border-width: 2px; }
.way-label { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); }
.way-label--gold { color: var(--gold); }
.way-card h3 { font-size: 1.4rem; color: var(--navy); margin: 0; }
.way-card--featured h3 { color: var(--white); }
.way-sub { font-size: 0.92rem; color: var(--muted); font-style: italic; margin: 0; }
.way-card--featured .way-sub { color: rgba(255,255,255,0.6); }
.way-divider { height: 1px; background: rgba(16,37,66,0.1); }
.way-card--featured .way-divider { background: rgba(255,255,255,0.12); }
.way-list { list-style: none; display: flex; flex-direction: column; gap: 0.6rem; padding: 0; margin: 0; }
.way-list li { font-size: 0.9rem; color: var(--ink); line-height: 1.6; padding-left: 1.25rem; position: relative; }
.way-list li::before { content: '→'; position: absolute; left: 0; color: var(--gold); font-weight: 700; }
.way-card--featured .way-list li { color: rgba(255,255,255,0.82); }
.way-list strong { color: var(--navy); font-weight: 700; }
.way-card--featured .way-list strong { color: var(--gold); }
.way-note { background: rgba(16,37,66,0.04); border-radius: 6px; padding: 0.9rem 1rem; font-size: 0.84rem; color: var(--muted); line-height: 1.6; }
.way-note--gold { background: rgba(194,162,74,0.12); }
.way-note strong { color: var(--navy); }
.way-note--gold strong { color: var(--gold); }

/* TRANSPARENCY */
.transparency-section { background: var(--white); }
.transparency-block { max-width: 820px; }
.gold-text { color: var(--gold); }
.t-text { font-size: 1rem; color: var(--muted); line-height: 1.8; }
.t-text strong { color: var(--navy); font-size: 1.05rem; }
.mt { margin-top: 1.25rem; }
.t-compare { display: flex; flex-direction: column; gap: 0.75rem; margin-top: 2rem; }
.t-compare-row { display: flex; gap: 1rem; align-items: flex-start; padding: 1.25rem 1.5rem; border-radius: var(--radius); }
.t-compare-bad { background: rgba(16,37,66,0.04); border: 1px solid rgba(16,37,66,0.08); }
.t-compare-good { background: var(--navy); border: 2px solid var(--gold); }
.t-icon { font-size: 1.1rem; font-weight: 700; flex-shrink: 0; margin-top: 0.1rem; }
.t-compare-bad .t-icon { color: var(--muted); }
.t-compare-good .t-icon { color: var(--gold); }
.t-compare-bad p { font-size: 0.92rem; color: var(--muted); line-height: 1.65; margin: 0; }
.t-compare-bad p em { text-decoration: line-through; color: var(--muted); font-style: normal; }
.t-compare-good p { font-size: 0.95rem; color: rgba(255,255,255,0.92); line-height: 1.65; margin: 0; }
.t-compare-good strong { color: var(--gold); }
.t-badge { display: inline-block; margin-top: 1.75rem; background: var(--gold); color: var(--navy-deep); font-size: 0.78rem; font-weight: 700; letter-spacing: 0.07em; text-transform: uppercase; padding: 0.5rem 1.25rem; border-radius: 4px; }

/* OFFER */
.offer-section { background: var(--navy-deep); text-align: center; }
.offer-inner { max-width: 600px; margin: 0 auto; }
.offer-eyebrow { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.75rem; }
.offer-inner h2 { color: var(--white); font-size: clamp(1.6rem,4vw,2.4rem); margin-bottom: 0.75rem; }
.offer-inner p { color: rgba(255,255,255,0.7); font-size: 0.95rem; line-height: 1.7; }
.offer-btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin-top: 1.5rem; }

@media (max-width: 800px) {
  .ways-grid { grid-template-columns: 1fr; }
  .step { grid-template-columns: 56px 1fr; }
}
</style>
