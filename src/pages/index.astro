---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABand from '../components/CTABand.astro';
import FurnitureViewer from '../components/FurnitureViewer';
import workData from '../data/work.json';
import reviewsData from '../data/reviews.json';

const reviews = reviewsData;

const services = [
  { icon: '🍳', name: 'Modular Kitchen', desc: 'Soft-close, durable, built to your space.', href: '/services/modular-kitchen' },
  { icon: '🛏️', name: 'Bedroom Furniture', desc: 'Wardrobes, beds, dressing tables.', href: '/services/wardrobes-bedroom' },
  { icon: '🛋️', name: 'Living Room Furniture', desc: 'TV units, sofas, shelves.', href: '/services' },
  { icon: '💼', name: 'Office Furniture', desc: 'Workstations, desks, reception counters.', href: '/services' },
  { icon: '🚪', name: 'Door & Window Frames', desc: 'Solid, precise, long-lasting.', href: '/services' },
  { icon: '✨', name: 'False Ceiling & Paneling', desc: 'Clean finishes that elevate a room.', href: '/services' },
  { icon: '🔧', name: 'Furniture Repair & Polishing', desc: 'Make old furniture look new.', href: '/services/furniture-repair' },
  { icon: '🪵', name: 'Custom Carpentry', desc: 'Anything in wood, made to order.', href: '/services' },
  { icon: '📦', name: 'Furniture Assembly', desc: 'Safe shifting, fitting, refitting.', href: '/services' },
  { icon: '🏺', name: 'Old Furniture Restoration', desc: 'Revive and re-polish treasured pieces.', href: '/services/furniture-repair' },
];

const faqs = [
  { q: 'Do you charge for a site visit?', a: 'No — site visits and inspections within 7 km are completely free.' },
  { q: 'Which areas of Indore do you cover?', a: 'All of Indore — Vijay Nagar, Palasia, Mahalaxmi Nagar, Tulsi Nagar, Rajendra Nagar, Nipaniya, Niranjanpur, Omex City, Dewas Naka, Talawali Chanda, County Walk, Singapur Township, Ansal Township, Shiv Vatika, SS Infinitus, Apollo DB City, Annapurna, Nanda Nagar, MR-10, Scheme 54, Old Palasia, AB Road and more.' },
  { q: 'Do you have a showroom?', a: "We work on-site across Indore. Just call or WhatsApp and we'll visit you for a free measurement." },
  { q: 'What\'s the difference between "With Material" and "Percentage Basis"?', a: 'With Material, we supply everything; on Percentage Basis, you arrange the material and we do the craftsmanship. Final pricing is discussed on a call or visit.' },
  { q: 'Do you offer any warranty?', a: 'Yes — a 1-year written warranty on our work.' },
  { q: 'How long does a project take?', a: 'Most furniture pieces take 7–15 days; full modular kitchens or wardrobes around 3–4 weeks.' },
  { q: 'Do you handle small repairs and polishing?', a: 'Absolutely — repairs, polishing, restoration, and modifications. First repair gets 10% off.' },
];

const featuredWork = workData.slice(0, 6);
---
<BaseLayout
  title="Best Carpenter & Furniture Contractor in Indore | VS Furnitures"
  description="VS Furnitures — trusted carpenter & furniture contractor in Indore with 30+ years experience. Modular kitchens, wardrobes, repairs & custom carpentry. Free site visit within 7 km. Call 9827348796."
>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg">
      <div class="hero-viewer">
        <FurnitureViewer
          client:visible
          fallbackImage="/images/hero-kitchen.jpg"
          fallbackAlt="Modular kitchen crafted by VS Furnitures, best carpenter in Indore"
        />
      </div>
      <div class="hero-overlay"></div>
    </div>
    <div class="container hero-content">
      <p class="eyebrow hero-eyebrow">INDORE · 30+ YEARS OF CRAFTSMANSHIP</p>
      <h1 class="hero-h1">Indore's Trusted Carpenter &amp; Custom Furniture Contractor</h1>
      <p class="hero-sub">Modular kitchens, wardrobes, interiors and repairs — handcrafted by a family of furniture contractors with 30+ years across Indore. <strong>Free site visit within 7 km.</strong></p>
      <div class="hero-btns">
        <a href="tel:+919827348796" class="btn btn-gold hero-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
          Call Now
        </a>
        <a href="https://wa.me/919977250002?text=Hi%20VS%20Furnitures%2C%20I%20found%20your%20website%20and%20I%27d%20like%20a%20free%20estimate%20for%20______" target="_blank" rel="noopener" class="btn btn-outline hero-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp Us
        </a>
      </div>
      <div class="hero-trust">
        <span>✦ 30+ Years</span>
        <span>✦ 700+ Modular Kitchens</span>
        <span>✦ 150+ Homes Furnished</span>
        <span>✦ 1-Year Written Warranty</span>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="stats-strip section-sm">
    <div class="container stats-grid">
      <div class="stat reveal"><span class="stat-num">30+</span><span class="stat-label">Years Experience</span></div>
      <div class="stat reveal"><span class="stat-num">700+</span><span class="stat-label">Modular Kitchens Built</span></div>
      <div class="stat reveal"><span class="stat-num">150+</span><span class="stat-label">Homes &amp; Flats Furnished</span></div>
      <div class="stat reveal"><span class="stat-num">1-Year</span><span class="stat-label">Written Warranty</span></div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="section services-section">
    <div class="container">
      <p class="eyebrow">What We Build</p>
      <h2>From a single repair to a full home fit-out</h2>
      <div class="gold-line"></div>
      <p class="section-sub reveal">Here's everything we make — designed, sourced, and built by our family team.</p>
      <div class="services-grid reveal">
        {services.map(s => (
          <a href={s.href} class="service-card">
            <span class="service-icon" role="img" aria-hidden="true">{s.icon}</span>
            <h3>{s.name}</h3>
            <p>{s.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTABand heading="Ready to start your project?" sub="Call or WhatsApp for your free site visit — anywhere in Indore." />

  <!-- WHY US -->
  <section class="section why-section texture-bg">
    <div class="container">
      <p class="eyebrow">Why VS Furnitures</p>
      <h2>A furniture contractor, not just a carpenter</h2>
      <div class="gold-line"></div>
      <div class="why-grid">
        {[
          { icon: '🕐', title: '30+ years in Indore', body: 'Three decades of homes and kitchens delivered across every neighbourhood.' },
          { icon: '🏗️', title: 'Contractor, not just a carpenter', body: 'We plan, source, manage and finish the whole project — one accountable team.' },
          { icon: '📋', title: '1-year written warranty', body: 'In writing, not just talk. We stand behind every piece we build.' },
          { icon: '🚗', title: 'Free site visit within 7 km', body: 'No charge, no obligation. We come to you, measure, and share an honest estimate.' },
          { icon: '🔄', title: 'Two flexible ways to work', body: 'With Material or Percentage Basis — whatever works for your project.' },
          { icon: '📍', title: 'Local & fast', body: 'We know Indore homes, local materials, and respond quickly to every enquiry.' },
        ].map(w => (
          <div class="why-card reveal">
            <span class="why-icon" role="img" aria-hidden="true">{w.icon}</span>
            <div>
              <h3>{w.title}</h3>
              <p>{w.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TWO WAYS -->
  <section class="section two-ways-section">
    <div class="container">
      <p class="eyebrow">How We Work</p>
      <h2>Two ways to work with us</h2>
      <div class="gold-line"></div>
      <div class="grid-2 two-ways-grid reveal">
        <div class="two-way-card">
          <div class="two-way-badge">Option 1</div>
          <h3>With Material</h3>
          <p>We handle everything, including sourcing the best-quality material your budget allows. One clear scope, zero hassle.</p>
          <ul>
            <li>✓ We source all materials</li>
            <li>✓ Single point of contact</li>
            <li>✓ No coordination headaches</li>
          </ul>
        </div>
        <div class="two-way-card">
          <div class="two-way-badge">Option 2</div>
          <h3>Percentage Basis</h3>
          <p>Prefer to arrange your own material? We provide the craftsmanship and execution — you control the material choice.</p>
          <ul>
            <li>✓ You choose your materials</li>
            <li>✓ Expert craftsmanship</li>
            <li>✓ Full project management</li>
          </ul>
        </div>
      </div>
      <p class="two-ways-note reveal">Final pricing is shared on a quick call or your free site visit.</p>
    </div>
  </section>

  <!-- OFFERS -->
  <section class="section-sm offers-section">
    <div class="container">
      <div class="offers-grid">
        <div class="offer-card reveal"><span class="offer-icon">📋</span><h3>1-Year Written Warranty</h3></div>
        <div class="offer-card reveal"><span class="offer-icon">🚗</span><h3>Free Site Visit within 7 km</h3></div>
        <div class="offer-card reveal"><span class="offer-icon">⚡</span><h3>Same-Day Furniture Repair</h3></div>
        <div class="offer-card reveal"><span class="offer-icon">🎁</span><h3>10% Off Your First Repair</h3></div>
      </div>
    </div>
  </section>

  <!-- RECENT WORK -->
  <section class="section work-section">
    <div class="container">
      <p class="eyebrow">Our Work</p>
      <h2>Recent projects across Indore</h2>
      <div class="gold-line"></div>
      <p class="section-sub reveal">Real homes, real projects. Photos supplied by our clients across Indore.</p>
      <div class="work-gallery reveal">
        {featuredWork.map(item => (
          <div class="work-item">
            <div class="work-img-wrap">
              <img src={item.image} alt={item.alt} loading="lazy" width="400" height="300" />
              <div class="work-overlay"><span class="work-cat">{item.category}</span></div>
            </div>
            <p class="work-title">{item.title}</p>
          </div>
        ))}
      </div>
      <div class="work-cta reveal">
        <a href="/our-work" class="btn btn-primary">See all our work →</a>
      </div>
    </div>
  </section>

  <CTABand />

  <!-- REVIEWS -->
  <section class="section reviews-section texture-bg">
    <div class="container">
      <p class="eyebrow">What Indore Says</p>
      <h2>Trusted by hundreds of Indore families</h2>
      <div class="gold-line"></div>
      <div class="reviews-grid reveal">
        {reviews.map(r => (
          <div class="review-card">
            <div class="review-stars">
              {'★'.repeat(r.stars)}
            </div>
            <p class="review-text">"{r.text}"</p>
            <div class="review-footer">
              <div class="reviewer-avatar">{r.name.charAt(0)}</div>
              <div>
                <p class="reviewer-name">{r.name}</p>
                <p class="reviewer-meta">{r.area} · {r.service}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- AREAS -->
  <section class="section-sm areas-section">
    <div class="container areas-inner">
      <div>
        <p class="eyebrow">Service Area</p>
        <h2>We serve all of Indore</h2>
        <div class="gold-line"></div>
      </div>
      <div class="areas-tags reveal">
        {['Vijay Nagar','Palasia','Mahalaxmi Nagar','Tulsi Nagar','Rajendra Nagar','Nipaniya','Niranjanpur','Omex City Phase 1 & 2','Dewas Naka','Talawali Chanda','County Walk','Singapur Township','Ansal Township','Shiv Vatika','SS Infinitus','Apollo DB City','Annapurna','Nanda Nagar','MR-10','Scheme 54','Old Palasia','AB Road'].map(a => (
          <span class="area-tag">{a}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section faq-section texture-bg">
    <div class="container">
      <p class="eyebrow">FAQ</p>
      <h2>Frequently asked questions</h2>
      <div class="gold-line"></div>
      <div class="faq-list">
        {faqs.map(faq => (
          <details class="faq-item reveal">
            <summary class="faq-q">
              <span>{faq.q}</span>
              <span class="faq-icon">+</span>
            </summary>
            <p class="faq-a">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CTABand heading="Get a free site visit anywhere in Indore." sub="No charge, no obligation. We come to you, measure, and share an honest estimate." />

</BaseLayout>

<style>
/* HERO */
.hero {
  position: relative;
  min-height: 92vh;
  display: flex;
  align-items: center;
  overflow: hidden;
  background: var(--navy-deep);
}
.hero-bg { position: absolute; inset: 0; }
.hero-viewer { position: absolute; inset: 0; left: 45%; }
.hero-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(90deg, var(--navy-deep) 45%, rgba(10,26,48,0.7) 70%, rgba(10,26,48,0.2) 100%);
}
.hero-content {
  position: relative; z-index: 2;
  max-width: 640px;
  padding-top: 80px; padding-bottom: 80px;
  animation: heroIn 0.8s ease both;
}
@keyframes heroIn { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:none; } }
.hero-eyebrow { color: var(--gold); margin-bottom: 1rem; }
.hero-h1 { font-size: clamp(2.2rem,5vw,3.5rem); color: var(--white); margin-bottom: 1.25rem; line-height: 1.15; }
.hero-sub { font-size: clamp(1rem,2vw,1.15rem); color: rgba(255,255,255,0.82); margin-bottom: 2rem; max-width: 520px; }
.hero-sub strong { color: var(--gold-soft); }
.hero-btns { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 2rem; }
.hero-btn { font-size: 1rem; padding: 0.85rem 2rem; }
.hero-trust { display: flex; flex-wrap: wrap; gap: 0.75rem 1.5rem; font-size: 0.8rem; color: rgba(255,255,255,0.6); font-weight: 600; letter-spacing: 0.04em; }
@media (max-width: 900px) {
  .hero-viewer { left: 0; }
  .hero-overlay { background: linear-gradient(0deg, var(--navy-deep) 40%, rgba(10,26,48,0.75) 80%); }
  .hero-content { max-width: 100%; padding-top: 120px; }
}

/* STATS */
.stats-strip { background: var(--navy); }
.stats-grid { display: grid; grid-template-columns: repeat(4,1fr); text-align: center; }
.stat { padding: 2rem 1rem; border-right: 1px solid rgba(255,255,255,0.1); }
.stat:last-child { border: none; }
.stat-num { display: block; font-family: var(--font-head); font-size: clamp(2rem,4vw,2.8rem); font-weight: 700; color: var(--gold); margin-bottom: 0.25rem; }
.stat-label { font-size: 0.82rem; font-weight: 600; color: rgba(255,255,255,0.7); letter-spacing: 0.04em; text-transform: uppercase; }
@media (max-width: 700px) { .stats-grid { grid-template-columns: repeat(2,1fr); } .stat:nth-child(2) { border-right: none; } }

/* SERVICES */
.section-sub { color: var(--muted); margin-bottom: 2.5rem; max-width: 560px; }
.services-grid { display: grid; grid-template-columns: repeat(5,1fr); gap: 1rem; }
.service-card { background: var(--white); border: 1px solid rgba(16,37,66,0.07); border-radius: var(--radius); padding: 1.25rem 1rem; text-decoration: none; transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s; display: flex; flex-direction: column; gap: 0.4rem; }
.service-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); border-color: var(--gold); }
.service-icon { font-size: 1.6rem; }
.service-card h3 { font-size: 0.9rem; font-family: var(--font-body); font-weight: 700; color: var(--navy); }
.service-card p { font-size: 0.78rem; color: var(--muted); line-height: 1.4; }
@media (max-width: 1100px) { .services-grid { grid-template-columns: repeat(4,1fr); } }
@media (max-width: 800px) { .services-grid { grid-template-columns: repeat(3,1fr); } }
@media (max-width: 550px) { .services-grid { grid-template-columns: repeat(2,1fr); } }

/* WHY */
.why-section { background: var(--paper); }
.why-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.5rem; margin-top: 1rem; }
.why-card { display: flex; gap: 1rem; align-items: flex-start; background: var(--white); border-radius: var(--radius); padding: 1.5rem; box-shadow: var(--shadow); }
.why-icon { font-size: 1.5rem; flex-shrink: 0; margin-top: 0.1rem; }
.why-card h3 { font-size: 0.95rem; font-family: var(--font-body); font-weight: 700; color: var(--navy); margin-bottom: 0.3rem; }
.why-card p { font-size: 0.85rem; color: var(--muted); line-height: 1.5; }
@media (max-width: 800px) { .why-grid { grid-template-columns: repeat(2,1fr); } }
@media (max-width: 550px) { .why-grid { grid-template-columns: 1fr; } }

/* TWO WAYS */
.two-ways-grid { gap: 2rem; margin-top: 1rem; }
.two-way-card { background: var(--white); border: 1px solid rgba(16,37,66,0.08); border-radius: var(--radius); padding: 2.5rem 2rem; box-shadow: var(--shadow); }
.two-way-badge { display: inline-block; background: var(--gold); color: var(--navy-deep); font-size: 0.72rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.2rem 0.6rem; border-radius: 3px; margin-bottom: 1rem; }
.two-way-card h3 { font-size: 1.4rem; color: var(--navy); margin-bottom: 0.75rem; }
.two-way-card p { color: var(--muted); margin-bottom: 1rem; }
.two-way-card ul { list-style: none; display: flex; flex-direction: column; gap: 0.4rem; }
.two-way-card li { font-size: 0.88rem; color: var(--ink); font-weight: 500; }
.two-ways-note { text-align: center; color: var(--muted); font-style: italic; margin-top: 1.5rem; }

/* OFFERS */
.offers-section { background: var(--navy-deep); }
.offers-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 1rem; }
.offer-card { background: rgba(255,255,255,0.05); border: 1px solid rgba(194,162,74,0.25); border-radius: var(--radius); padding: 1.75rem 1.25rem; text-align: center; }
.offer-icon { font-size: 2rem; display: block; margin-bottom: 0.75rem; }
.offer-card h3 { font-family: var(--font-body); font-size: 0.9rem; font-weight: 700; color: var(--white); }
@media (max-width: 700px) { .offers-grid { grid-template-columns: repeat(2,1fr); } }

/* WORK */
.work-gallery { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.25rem; margin-bottom: 2rem; }
.work-img-wrap { position: relative; overflow: hidden; border-radius: var(--radius); aspect-ratio: 4/3; background: #e8e0d5; }
.work-img-wrap img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.35s ease; }
.work-item:hover img { transform: scale(1.04); }
.work-overlay { position: absolute; bottom: 0; left: 0; right: 0; background: linear-gradient(0deg,rgba(16,37,66,0.85) 0%,transparent 100%); padding: 1rem 0.75rem 0.5rem; opacity: 0; transition: opacity 0.25s; }
.work-item:hover .work-overlay { opacity: 1; }
.work-cat { font-size: 0.75rem; font-weight: 700; color: var(--gold); letter-spacing: 0.1em; text-transform: uppercase; }
.work-title { font-size: 0.85rem; font-weight: 600; color: var(--muted); margin-top: 0.5rem; }
.work-cta { text-align: center; }
@media (max-width: 700px) { .work-gallery { grid-template-columns: repeat(2,1fr); } }

/* AREAS */
.areas-section { background: var(--paper); }
.areas-inner { display: flex; gap: 3rem; align-items: flex-start; }
.areas-tags { display: flex; flex-wrap: wrap; gap: 0.6rem; padding-top: 0.5rem; flex: 1; }
.area-tag { background: var(--white); border: 1px solid rgba(16,37,66,0.12); border-radius: 40px; padding: 0.35rem 1rem; font-size: 0.85rem; font-weight: 600; color: var(--navy); }
@media (max-width: 700px) { .areas-inner { flex-direction: column; gap: 1.5rem; } }

/* REVIEWS */
.reviews-section { background: var(--paper); }
.reviews-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.25rem;
  margin-top: 0.5rem;
}
.review-card {
  background: var(--white);
  border: 1px solid rgba(16,37,66,0.07);
  border-radius: var(--radius);
  padding: 1.4rem;
  box-shadow: var(--shadow);
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}
.review-stars { color: var(--gold); font-size: 0.95rem; letter-spacing: 0.05em; }
.review-text { font-size: 0.85rem; color: var(--ink); line-height: 1.6; flex: 1; }
.review-footer { display: flex; gap: 0.75rem; align-items: center; padding-top: 0.75rem; border-top: 1px solid rgba(16,37,66,0.06); }
.reviewer-avatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: var(--navy);
  color: var(--gold);
  font-family: var(--font-head);
  font-size: 1rem;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
