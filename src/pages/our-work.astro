---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABand from '../components/CTABand.astro';
import workData from '../data/work.json';

const categories = ['All', ...Array.from(new Set(workData.map(w => w.category)))];
---
<BaseLayout
  title="Our Work — Furniture Projects in Indore | VS Furnitures"
  description="Browse real furniture projects by VS Furnitures — modular kitchens, wardrobes, living room, office furniture, and repairs across Indore. 30+ years of craftsmanship."
>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Portfolio</p>
      <h1>Our Work Across Indore</h1>
      <div class="gold-line"></div>
      <p class="page-hero-sub">Real projects, real homes. A selection of kitchens, wardrobes, living rooms, offices and repairs we've completed across Indore.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <!-- Filter buttons (JS progressive enhancement) -->
      <div class="filter-bar" id="filterBar">
        {categories.map(cat => (
          <button class:list={['filter-btn', { active: cat === 'All' }]} data-filter={cat}>{cat}</button>
        ))}
      </div>

      <div class="work-grid" id="workGrid">
        {workData.map(item => (
          <div class="work-card reveal" data-category={item.category}>
            <div class="work-img-wrap">
              <img src={item.image} alt={item.alt} loading="lazy" width="400" height="300" />
              <div class="work-overlay"><span class="work-cat">{item.category}</span></div>
            </div>
            <p class="work-title">{item.title}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABand heading="Like what you see?" sub="Call or WhatsApp to discuss your project — free site visit anywhere in Indore." />
</BaseLayout>

<style>
.page-hero { background: var(--navy-deep); padding: 96px 0 64px; text-align: center; }
.page-hero h1 { color: var(--white); font-size: clamp(2rem,5vw,3rem); }
.page-hero .eyebrow { display: block; }
.page-hero .gold-line { margin: 1rem auto 1.5rem; }
.page-hero-sub { color: rgba(255,255,255,0.7); max-width: 560px; margin: 0 auto; }

.filter-bar { display: flex; flex-wrap: wrap; gap: 0.6rem; margin-bottom: 2.5rem; }
.filter-btn { background: var(--white); border: 1px solid rgba(16,37,66,0.15); border-radius: 40px; padding: 0.4rem 1.1rem; font-size: 0.85rem; font-weight: 600; color: var(--navy); cursor: pointer; transition: all 0.15s; }
.filter-btn.active, .filter-btn:hover { background: var(--navy); color: var(--white); border-color: var(--navy); }

.work-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.5rem; }
.work-card { cursor: default; }
.work-img-wrap { position: relative; overflow: hidden; border-radius: var(--radius); aspect-ratio: 4/3; background: #e8e0d5; }
.work-img-wrap img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.35s; }
.work-card:hover img { transform: scale(1.04); }
.work-overlay { position: absolute; bottom: 0; left: 0; right: 0; background: linear-gradient(0deg,rgba(16,37,66,0.85) 0%,transparent); padding: 1rem 0.75rem 0.5rem; opacity: 0; transition: opacity 0.25s; }
.work-card:hover .work-overlay { opacity: 1; }
.work-cat { font-size: 0.75rem; font-weight: 700; color: var(--gold); letter-spacing: 0.1em; text-transform: uppercase; }
.work-title { font-size: 0.85rem; font-weight: 600; color: var(--muted); margin-top: 0.5rem; }
.work-card.hidden { display: none; }

@media (max-width: 700px) { .work-grid { grid-template-columns: repeat(2,1fr); } }
@media (max-width: 400px) { .work-grid { grid-template-columns: 1fr; } }
</style>

<script>
const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
const cards   = document.querySelectorAll<HTMLElement>('.work-card');

buttons.forEach(btn => {
  btn.addEventListener('click', () => {
    buttons.forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const filter = btn.dataset.filter;
    cards.forEach(card => {
      card.classList.toggle('hidden', filter !== 'All' && card.dataset.category !== filter);
    });
  });
});
</script>
