---
import { readdirSync } from 'fs';
import { join } from 'path';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABand from '../../components/CTABand.astro';
import categories from '../../data/work-categories.json';

export function getStaticPaths() {
  return categories.map(cat => ({ params: { category: cat.slug } }));
}

const { category } = Astro.params;
const cat = categories.find(c => c.slug === category)!;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type":"ListItem","position":1,"name":"Home","item":"https://vsfurnitures.in"},
    {"@type":"ListItem","position":2,"name":"Our Work","item":"https://vsfurnitures.in/our-work"},
    {"@type":"ListItem","position":3,"name":cat.title,"item":`https://vsfurnitures.in/our-work/${category}`}
  ]
};

const IMAGE_EXTS = /\.(jpg|jpeg|png|webp|avif)$/i;
const imageDir = join(process.cwd(), 'public', 'images', 'work', category);
let images: string[] = [];
try {
  images = readdirSync(imageDir)
    .filter(f => IMAGE_EXTS.test(f))
    .sort()
    .map(f => `/images/work/${category}/${f}`);
} catch {}
---
<BaseLayout
  title={`${cat.title} — Portfolio | VS Furnitures Indore`}
  description={`Browse ${cat.title.toLowerCase()} projects by VS Furnitures in Indore. ${cat.description}`}
  additionalSchemas={[breadcrumbSchema]}
>
  <section class="page-hero">
    <div class="container">
      <a href="/our-work" class="back-link">← All Categories</a>
      <p class="eyebrow">Our Work</p>
      <h1>{cat.title}</h1>
      <div class="gold-line"></div>
      <p class="page-hero-sub">{cat.description}</p>
      {images.length > 0 && <p class="photo-count">{images.length} photos</p>}
    </div>
  </section>

  <section class="section">
    <div class="container">
      {images.length > 0 ? (
        <div class="gallery-grid" id="galleryGrid">
          {images.map((src, i) => (
            <button
              class="gallery-item"
              data-index={i}
              data-src={src}
              data-alt={`${cat.title} by VS Furnitures Indore — design ${i + 1}`}
              aria-label={`View ${cat.title} photo ${i + 1}`}
            >
              <img
                src={src}
                alt={`${cat.title} by VS Furnitures Indore — design ${i + 1}`}
                loading="lazy"
                width="400"
                height="300"
              />
              <div class="item-overlay">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/><path d="M11 8v6M8 11h6"/></svg>
              </div>
            </button>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <p>Photos for this category are coming soon.</p>
          <a href="/contact" class="btn btn-primary">Contact us to discuss your project</a>
        </div>
      )}
    </div>
  </section>

  <!-- Lightbox -->
  <div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label="Photo viewer" aria-hidden="true">
    <button class="lb-close" id="lbClose" aria-label="Close photo viewer">✕</button>
    <button class="lb-prev" id="lbPrev" aria-label="Previous photo">‹</button>
    <button class="lb-next" id="lbNext" aria-label="Next photo">›</button>
    <div class="lb-inner">
      <img id="lbImg" src="" alt="" />
    </div>
    <p class="lb-counter" id="lbCounter"></p>
  </div>

  <section class="section gallery-about">
    <div class="container gallery-about-inner">
      <p class="eyebrow">VS Furnitures — Indore</p>
      <h2>About our {cat.title.toLowerCase()} work</h2>
      <div class="gold-line"></div>
      <p>{cat.description}</p>
      <p class="mt">Every project shown here was built for a real client in Indore — from Vijay Nagar and Palasia to Rau, Scheme 54, and Nanda Nagar. Each piece is custom-made to the client's exact room dimensions, material preferences, and budget. No standard sizes, no catalogue items.</p>
      <p class="mt">We bring 30+ years of experience to every build. All work comes with a <strong>1-year written warranty</strong> on workmanship and hardware. Free site visit available anywhere within 7 km of Indore — call or WhatsApp to book.</p>
      <div class="gallery-about-cta mt">
        <a href="/contact" class="btn btn-primary">Request Free Site Visit</a>
        <a href="/services" class="btn btn-outline-nav">View All Services</a>
      </div>
    </div>
  </section>

  <CTABand
    heading={`Inspired by our ${cat.title.toLowerCase()}?`}
    sub="Call or WhatsApp for a free site visit — anywhere in Indore."
  />
</BaseLayout>

<style>
.page-hero { background: var(--navy-deep); padding: 96px 0 64px; text-align: center; }
.page-hero h1 { color: var(--white); font-size: clamp(2rem,5vw,3rem); }
.page-hero .eyebrow { display: block; }
.page-hero .gold-line { margin: 1rem auto 1.5rem; }
.page-hero-sub { color: rgba(255,255,255,0.7); max-width: 580px; margin: 0 auto; }
.photo-count { color: var(--gold); font-size: 0.85rem; font-weight: 600; margin-top: 0.75rem; letter-spacing: 0.05em; }

.back-link {
  display: inline-block;
  color: rgba(255,255,255,0.55);
  font-size: 0.85rem;
  font-weight: 600;
  text-decoration: none;
  margin-bottom: 1.5rem;
  transition: color 0.15s;
  letter-spacing: 0.03em;
}
.back-link:hover { color: var(--gold); }

.gallery-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0.75rem;
}

.gallery-item {
  position: relative;
  aspect-ratio: 1;
  overflow: hidden;
  border-radius: 6px;
  cursor: pointer;
  background: #e8e0d5;
  border: none;
  padding: 0;
  display: block;
}
.gallery-item img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.35s ease;
  display: block;
}
.gallery-item:hover img { transform: scale(1.06); }

.item-overlay {
  position: absolute;
  inset: 0;
  background: rgba(16,37,66,0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--white);
  opacity: 0;
  transition: opacity 0.25s;
}
.gallery-item:hover .item-overlay { opacity: 1; }

.empty-state {
  text-align: center;
  padding: 4rem 1rem;
  color: var(--muted);
}
.empty-state p { margin-bottom: 1.5rem; font-size: 1rem; }

/* Lightbox */
.lightbox {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.93);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s;
}
.lightbox.active {
  opacity: 1;
  pointer-events: all;
}
.lb-inner {
  max-width: 90vw;
  max-height: 85vh;
  display: flex;
  align-items: center;
  justify-content: center;
}
.lb-inner img {
  max-width: 90vw;
  max-height: 85vh;
  object-fit: contain;
  border-radius: 4px;
  box-shadow: 0 8px 48px rgba(0,0,0,0.6);
  display: block;
}
.lb-close {
  position: fixed;
  top: 1.25rem;
  right: 1.5rem;
  background: none;
  border: none;
  color: rgba(255,255,255,0.75);
  font-size: 1.6rem;
  cursor: pointer;
  line-height: 1;
  padding: 0.25rem 0.5rem;
  transition: color 0.15s;
  z-index: 1001;
}
.lb-close:hover { color: var(--white); }
.lb-prev, .lb-next {
  position: fixed;
  top: 50%;
  transform: translateY(-50%);
  background: rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.2);
  color: var(--white);
  font-size: 2.5rem;
  line-height: 1;
  cursor: pointer;
  padding: 0.5rem 0.9rem;
  border-radius: 4px;
  transition: background 0.15s;
  z-index: 1001;
}
.lb-prev { left: 1.25rem; }
.lb-next { right: 1.25rem; }
.lb-prev:hover, .lb-next:hover { background: rgba(255,255,255,0.22); }
.lb-counter {
  position: fixed;
  bottom: 1.25rem;
  left: 50%;
  transform: translateX(-50%);
  color: rgba(255,255,255,0.5);
  font-size: 0.82rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  pointer-events: none;
}

.gallery-about { background: var(--paper); }
.gallery-about-inner { max-width: 720px; }
.gallery-about-inner p { color: var(--muted); line-height: 1.75; font-size: 0.95rem; }
.gallery-about-inner strong { color: var(--navy); }
.mt { margin-top: 1rem; }
.gallery-about-cta { display: flex; gap: 1rem; flex-wrap: wrap; }
.btn-outline-nav { background: transparent; border: 2px solid var(--navy); color: var(--navy); padding: 0.75rem 1.75rem; border-radius: var(--radius); font-weight: 700; text-decoration: none; font-size: 0.9rem; transition: background 0.2s, color 0.2s; }
.btn-outline-nav:hover { background: var(--navy); color: var(--white); }
@media (max-width: 1100px) { .gallery-grid { grid-template-columns: repeat(3, 1fr); } }
@media (max-width: 700px)  { .gallery-grid { grid-template-columns: repeat(2, 1fr); gap: 0.5rem; } }
@media (max-width: 400px)  { .gallery-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 600px)  { .lb-prev { left: 0.5rem; } .lb-next { right: 0.5rem; } }
</style>

<script>
const items = document.querySelectorAll<HTMLButtonElement>('.gallery-item');
const lightbox = document.getElementById('lightbox')!;
const lbImg = document.getElementById('lbImg') as HTMLImageElement;
const lbCounter = document.getElementById('lbCounter')!;
const lbClose = document.getElementById('lbClose')!;
const lbPrev = document.getElementById('lbPrev')!;
const lbNext = document.getElementById('lbNext')!;

const photos = Array.from(items).map(el => ({
  src: el.dataset.src!,
  alt: el.dataset.alt!,
}));
const total = photos.length;
let current = 0;

function open(index: number) {
  current = (index + total) % total;
  lbImg.src = photos[current].src;
  lbImg.alt = photos[current].alt;
  lbCounter.textContent = `${current + 1} / ${total}`;
  lightbox.classList.add('active');
  lightbox.setAttribute('aria-hidden', 'false');
  document.body.style.overflow = 'hidden';
}

function close() {
  lightbox.classList.remove('active');
  lightbox.setAttribute('aria-hidden', 'true');
  document.body.style.overflow = '';
}

items.forEach(el => el.addEventListener('click', () => open(parseInt(el.dataset.index!))));
lbClose.addEventListener('click', close);
lbPrev.addEventListener('click', () => open(current - 1));
lbNext.addEventListener('click', () => open(current + 1));
lightbox.addEventListener('click', e => { if (e.target === lightbox) close(); });
document.addEventListener('keydown', e => {
  if (!lightbox.classList.contains('active')) return;
  if (e.key === 'Escape') close();
  if (e.key === 'ArrowLeft') open(current - 1);
  if (e.key === 'ArrowRight') open(current + 1);
});
</script>
