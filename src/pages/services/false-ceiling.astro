---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABand from '../../components/CTABand.astro';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type":"ListItem","position":1,"name":"Home","item":"https://vsfurnitures.in"},
    {"@type":"ListItem","position":2,"name":"Services","item":"https://vsfurnitures.in/services"},
    {"@type":"ListItem","position":3,"name":"False Ceiling & Wood Paneling","item":"https://vsfurnitures.in/services/false-ceiling"}
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "False Ceiling",
  "name": "False Ceiling & Wood Paneling in Indore",
  "description": "POP false ceiling, gypsum ceiling and wood wall paneling in Indore. Custom lighting cutouts, cornice work, clean finish. VS Furnitures — 30+ years. Free site visit.",
  "provider": {"@id": "https://vsfurnitures.in/#business"},
  "areaServed": "Indore, Madhya Pradesh",
  "url": "https://vsfurnitures.in/services/false-ceiling",
  "offers": {
    "@type": "Offer",
    "priceCurrency": "INR",
    "priceRange": "Contact us for quotation",
    "availability": "https://schema.org/InStock"
  }
};
---
<BaseLayout
  title="False Ceiling in Indore | POP, Gypsum & Wood Paneling | VS Furnitures"
  description="POP false ceiling, gypsum ceiling and wood wall paneling in Indore. Custom lighting cutouts, cornice work, clean finish. VS Furnitures — 30+ years. Free site visit."
  additionalSchemas={[breadcrumbSchema, serviceSchema]}
>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Service</p>
      <h1>False Ceiling &amp; Wood Paneling in Indore</h1>
      <div class="gold-line"></div>
      <p class="page-hero-sub">POP, gypsum, and wood panel ceilings and feature walls that transform the look of any room. Crew cleans up completely before leaving.</p>
      <div class="hero-btns">
        <a href="tel:+919827348796" class="btn btn-gold">Call for Free Estimate</a>
        <a href="https://wa.me/919977250002?text=Hi%20VS%20Furnitures%2C%20I%20need%20a%20false%20ceiling%20in%20Indore.%20Can%20I%20get%20a%20free%20site%20visit%3F" target="_blank" rel="noopener" class="btn btn-outline">WhatsApp Us</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="ceiling-grid reveal">

        <div class="ceiling-card">
          <div class="ceiling-icon">🏛️</div>
          <h2>POP False Ceiling</h2>
          <div class="gold-line"></div>
          <p>Plaster of Paris (POP) is the most popular false ceiling choice for Indore homes. It allows curved shapes, coves, cornices, and multi-level designs that are impossible with flat board ceilings.</p>
          <ul class="check-list mt">
            <li>Custom shapes — coves, domes, stepped levels</li>
            <li>Cornice and border detailing</li>
            <li>Recessed lighting cutouts — any layout</li>
            <li>Smooth paint-ready finish</li>
            <li>Fan and AC duct integration</li>
          </ul>
          <p class="price-note mt">Contact us for a free site visit and per sq ft estimate.</p>
        </div>

        <div class="ceiling-card">
          <div class="ceiling-icon">⬜</div>
          <h2>Gypsum Board Ceiling</h2>
          <div class="gold-line"></div>
          <p>Gypsum board gives a clean, flat, modern finish. It is quicker to install than POP and is the preferred choice for offices, commercial spaces, and contemporary home interiors.</p>
          <ul class="check-list mt">
            <li>Flat finish — ideal for modern interiors</li>
            <li>Faster installation than POP</li>
            <li>Lightweight — does not add ceiling load</li>
            <li>Recessed downlight and track light ready</li>
            <li>Easy to patch and repaint</li>
          </ul>
          <p class="price-note mt">Contact us for a free site visit and per sq ft estimate.</p>
        </div>

        <div class="ceiling-card">
          <div class="ceiling-icon">🪵</div>
          <h2>Wood Paneling</h2>
          <div class="gold-line"></div>
          <p>A wood-paneled accent wall or ceiling feature immediately changes the character of a room. We use laminate, veneer, or real wood slat panels — all cut and fitted on site.</p>
          <ul class="check-list mt">
            <li>Bedroom headboard wall paneling</li>
            <li>Living room feature walls</li>
            <li>Wood slat ceiling panels</li>
            <li>TV unit integrated wall panel</li>
            <li>Natural wood, dark walnut, light oak finishes</li>
          </ul>
          <p class="price-note mt">Contact us for a free site visit and per sq ft estimate.</p>
        </div>

      </div>
    </div>
  </section>

  <section class="promise-section section-sm">
    <div class="container promise-inner">
      <div class="promise-badge">Our Promise</div>
      <h2>We clean up completely before we leave</h2>
      <p>Ceiling and paneling work creates dust and debris. Our crew brings tarpaulins to cover your furniture, sweeps and clears all debris, and wipes down surfaces before leaving. Your room is ready to use the same day we finish — this is something our clients mention specifically in their reviews.</p>
    </div>
  </section>

  <section class="faq-section section texture-bg">
    <div class="container">
      <p class="eyebrow">FAQ</p>
      <h2>False ceiling — common questions</h2>
      <div class="gold-line"></div>
      <div class="faq-list">
        {[
          { q: 'How long does a false ceiling take to install?', a: 'A standard bedroom or living room ceiling takes 2 to 4 days depending on design complexity. Gypsum ceilings are typically faster than POP ceilings with custom shapes.' },
          { q: 'Will it reduce my room height significantly?', a: 'A standard false ceiling drops the ceiling by 4 to 8 inches (10 to 20 cm). For rooms with 10-foot or higher ceilings this is barely noticeable. We measure your room first and advise on the right drop height.' },
          { q: 'Can you add LED lighting in the false ceiling?', a: 'Yes — recessed downlights, cove LED strips, and track lighting can all be integrated into the ceiling design. We plan the lighting layout along with the ceiling design.' },
        ].map(faq => (
          <details class="faq-item">
            <summary class="faq-q">
              <span>{faq.q}</span>
              <span class="faq-icon">+</span>
            </summary>
            <p class="faq-a">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CTABand heading="Thinking about a false ceiling?" sub="Call or WhatsApp for a free site visit — we measure, suggest a design, and give you an honest per sq ft estimate." />
</BaseLayout>

<style>
.page-hero { background: var(--navy-deep); padding: 96px 0 64px; text-align: center; }
.page-hero h1 { color: var(--white); font-size: clamp(2rem,5vw,3rem); }
.page-hero .eyebrow { display: block; }
.page-hero .gold-line { margin: 1rem auto 1.5rem; }
.page-hero-sub { color: rgba(255,255,255,0.75); max-width: 580px; margin: 0 auto 2rem; font-size: 1.05rem; }
.hero-btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
.ceiling-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.5rem; }
.ceiling-card { background: var(--white); border: 1px solid rgba(16,37,66,0.08); border-radius: var(--radius); padding: 2rem; box-shadow: var(--shadow); }
.ceiling-icon { font-size: 2.2rem; margin-bottom: 0.75rem; }
.ceiling-card h2 { font-size: 1.3rem; margin-bottom: 0.25rem; }
.ceiling-card .gold-line { margin: 0.75rem 0 1rem; }
.ceiling-card p { color: var(--muted); font-size: 0.9rem; line-height: 1.6; }
.mt { margin-top: 1rem; }
.check-list { list-style: none; display: flex; flex-direction: column; gap: 0.35rem; }
.check-list li { font-size: 0.88rem; color: var(--ink); font-weight: 500; }
.check-list li::before { content: '✓ '; color: var(--gold); font-weight: 700; }
.price-note { font-size: 0.88rem; color: var(--muted); }
.price-note strong { color: var(--navy); }
.promise-section { background: var(--navy); text-align: center; }
.promise-inner { max-width: 640px; margin: 0 auto; }
.promise-badge { display: inline-block; background: var(--gold); color: var(--navy-deep); font-size: 0.72rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.2rem 0.7rem; border-radius: 3px; margin-bottom: 1rem; }
.promise-inner h2 { color: var(--white); margin-bottom: 0.75rem; }
.promise-inner p { color: rgba(255,255,255,0.72); font-size: 0.92rem; line-height: 1.7; }
.faq-list { max-width: 760px; margin-top: 1rem; display: flex; flex-direction: column; gap: 0.75rem; }
.faq-item { background: var(--white); border: 1px solid rgba(16,37,66,0.08); border-radius: var(--radius); overflow: hidden; }
.faq-q { display: flex; align-items: center; justify-content: space-between; padding: 1.1rem 1.25rem; font-weight: 600; font-size: 0.95rem; cursor: pointer; list-style: none; color: var(--navy); }
.faq-q::-webkit-details-marker { display: none; }
.faq-icon { font-size: 1.25rem; color: var(--gold); flex-shrink: 0; transition: transform 0.2s; }
.faq-item[open] .faq-icon { transform: rotate(45deg); }
.faq-a { padding: 0 1.25rem 1rem; color: var(--muted); font-size: 0.9rem; line-height: 1.6; }
@media (max-width: 900px) { .ceiling-grid { grid-template-columns: 1fr 1fr; } }
@media (max-width: 600px) { .ceiling-grid { grid-template-columns: 1fr; } }
</style>
